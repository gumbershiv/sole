public without sharing class B2BDistributorCartService {
    
    @AuraEnabled(cacheable=false)
    public static B2BActionResponse handleDistributorCart(String communityId) {
        
        try {
            Id userId     = UserInfo.getUserId();
            String persona = B2BUtil.getCurrentUserPersona();
            Id acctId     = B2BUtil.getEffectiveAccountId();
            Id webstoreId = B2BUtil.resolveCommunityIdToWebstoreId(communityId);
            
            // Persona validation
            if (persona != 'DIST_AS_CUSTOMER' && persona != 'DIST_DOUBLE_DISCOUNT') {
                return new B2BActionResponse(false, 'Not in Scope', null);
            }
            
            // Get all ACTIVE carts
            List<WebCart> activeCarts = [
                SELECT Id, Name, Status, IsSecondary
                FROM WebCart
                WHERE OwnerId = :userId
                    AND AccountId = :acctId
                    AND WebStoreId = :webstoreId
                    AND Status = 'Active'
            ];
            
            WebCart primaryCart;
            WebCart personaCart;
            
            // Identify carts
            for (WebCart cart : activeCarts) {
                if (!cart.IsSecondary) {
                    primaryCart = cart;
                }
                if (cart.Name != null && cart.Name == ('Cart ' + persona)) {
                    personaCart = cart;
                }
            }
            
            // Persona cart already primary - no refresh
            if (personaCart != null && !personaCart.IsSecondary) {
                return new B2BActionResponse(false, 'Do Not Refresh Cart', personaCart);
            }
            
            List<WebCart> cartsToUpdate = new List<WebCart>();
            
            // Persona cart exists but secondary - need upgrade
            if (personaCart != null) {
                
                if (primaryCart != null) {
                    primaryCart.IsSecondary = true;
                    cartsToUpdate.add(primaryCart);
                }
                
                personaCart.IsSecondary = false;
                cartsToUpdate.add(personaCart);
                
                update cartsToUpdate;
                
                return new B2BActionResponse(true, 'Refresh Cart', personaCart);
            }
            
            // Persona cart does not exist - create new primary
            
            if (primaryCart != null) {
                primaryCart.IsSecondary = true;
                update primaryCart;
            }
            
            Id newCart = createCart(userId, persona, acctId, webstoreId);
            
            return new B2BActionResponse(true, 'Refresh Cart', newCart);
            
        } catch (Exception ex) {
            
            B2BLoggingUtil.error(
                'ORDER_DETAIL_LOGGERERR',
                'B2BDistributorCartService',
                'handleDistributorCart',
                ex.getLineNumber(),
                ex.getMessage(),
                null
            );
            
            return new B2BActionResponse(false, ex.getMessage(), null);
            
        } finally {
            B2BLoggingUtil.flush();
        }
    }
    
    
    private static Id createCart(Id userId, String persona, Id acctId, Id webstoreId) {
        
        ConnectApi.CartInput cartInput = new ConnectApi.CartInput();
        cartInput.effectiveAccountId = acctId;
        cartInput.isSecondary = false;
        cartInput.name = 'Cart ' + persona;
        cartInput.type = ConnectApi.CartType.CART;
        ConnectApi.CartSummary cartSumm;
        if(test.isRunningTest()){
            cartSumm = B2BCartSwitcherServiceTest.makeTestCommerceCartSummary(webstoreId,acctId,userId);
        }else{
            cartSumm = ConnectApi.CommerceCart.createCart(webstoreId, cartInput);
        }
        return cartSumm.cartId;
    }
}
