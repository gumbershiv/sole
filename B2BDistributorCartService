public without sharing class B2BDistributorCartService {

    @AuraEnabled(cacheable=false)
    public static B2BActionResponse handleDistributorCart(String communityId) {

        try {
            Id userId     = UserInfo.getUserId();
            String persona = B2BUtil.getCurrentUserPersona();
            Id acctId     = B2BUtil.getEffectiveAccountId();
            Id webstoreId = B2BUtil.resolveCommunityIdToWebstoreId(communityId);

            // Persona validation
            if (persona != 'DIST_AS_CUSTOMER' && persona != 'DIST_DOUBLE_DISCOUNT') {
                return new B2BActionResponse(false, 'Not in Scope', null);
            }

            // Get all ACTIVE carts for user/account/store
            List<WebCart> activeCarts = [
                SELECT Id, Name, Status, IsSecondary
                FROM WebCart
                WHERE OwnerId = :userId
                AND AccountId = :acctId
                AND WebStoreId = :webstoreId
                AND Status = 'Active'
            ];

            WebCart primaryCart;
            WebCart personaCart;

            // Identify carts
            for (WebCart cart : activeCarts) {
                if (!cart.IsSecondary) {
                    primaryCart = cart;
                }
                if (cart.Name != null && cart.Name == ('Cart ' + persona)) {
                    personaCart = cart;
                }
            }

            // ✅ Case 1: Persona cart already primary → no refresh
            if (personaCart != null && !personaCart.IsSecondary) {
                return new B2BActionResponse(false, 'Do Not Refresh Cart', personaCart);
            }

            List<WebCart> cartsToUpdate = new List<WebCart>();

            // ✅ Case 2: Persona cart exists but secondary → promote it
            if (personaCart != null) {

                if (primaryCart != null) {
                    primaryCart.IsSecondary = true;
                    cartsToUpdate.add(primaryCart);
                }

                personaCart.IsSecondary = false;
                cartsToUpdate.add(personaCart);

                update cartsToUpdate;

                return new B2BActionResponse(true, 'Switched To Existing Persona Cart', personaCart);
            }

            // ✅ Case 3: Persona cart does not exist → create new primary

            if (primaryCart != null) {
                primaryCart.IsSecondary = true;
                update primaryCart;
            }

            WebCart newCart = createCart(userId, persona, acctId, webstoreId);

            return new B2BActionResponse(true, 'Created New Persona Cart', newCart);

        } catch (Exception ex) {

            B2BLoggingUtil.error(
                'ORDER_DETAIL_LOGGERERR',
                'B2BDistributorCartService',
                'handleDistributorCart',
                ex.getLineNumber(),
                ex.getMessage(),
                null
            );

            return new B2BActionResponse(false, ex.getMessage(), null);

        } finally {
            B2BLoggingUtil.flush();
        }
    }


    private static WebCart createCart(Id userId, String persona, Id acctId, Id webstoreId) {

        WebCart cart = new WebCart();
        cart.OwnerId = userId;
        cart.Name = 'Cart ' + persona;
        cart.Status = 'Active';
        cart.IsSecondary = false; // Always primary when created
        cart.AccountId = acctId;
        cart.WebStoreId = webstoreId;
        cart.B2B_CartType__c = 'Cart';

        insert cart;
        return cart;
    }
}