                    'FROM B2B_PackagePart__c ' +
                    'WHERE B2B_Package__r.Id = :thePackageId ' +
                    partsWhere +
                    'ORDER BY ' + input.sortColumn + ' ' + sortDirection + ' ' +
                    'LIMIT ' + input.pageSize + ' OFFSET ' + (input.page * input.pageSize) ;
        } else {
            //This section is when user has clicked in the "category tree"  We need to get
            //products either at the System or Sub-System level
            List<String> catParts = input.systemOrSubsystemRefinement.split('~');
