        /**
         * transferFieldsData will set ProductData from "fields" data that is used to make sell-ability decisions (and possible other
         * high-level data) to expose directly within the wrapper data object.
         *
         * @param fields Map<String, String> The incoming field/value map from the ConnectApi
         */
        private void transferFieldsData(Map<String, String> fields) {
            this.fields = fields;
            try {
                this.sellable = Boolean.valueOf(fields.get('B2B_IsProductSellable__c'));
            } catch (NullPointerException npe) {
                this.sellable = false;
            }
            try {
                this.insalecategory = Boolean.valueOf(fields.get('B2B_IsSaleCategoryProduct__c'));
            } catch (NullPointerException npe) {
                this.insalecategory = false;
            }
            try {
                this.isActive = Boolean.valueOf(fields.get('IsActive'));
            } catch (NullPointerException npe) {
                this.isActive = false;
            }
            this.leadTime = fields.get('B2B_LEAD_TIME__c');
            this.finalPart = fields.get('B2B_Replaced_By__c');
            if (String.isNotBlank(finalPart)) {
                FINAL_PART_SET_FOR_ID_RETRIEVAL.add(this.finalPart);
            }
            this.uom = fields.get('B2B_UNITS__c');
            this.uomqty = fields.get('B2B_PACK_QUANTITY__c');

            try {
                if ((this.uomqty == '1') || (this.uomqty == '1.0')) {
                    this.uomMessage = this.uom.toLowerCase();
                } else {
                    this.uomMessage = this.uom.toLowerCase() + ' of ' + this.uomqty;
                }
            } catch (Exception e) {
                this.uomMessage = 'each';
            }
        }

        /**
         * removeFields will remove the extra fields data from the payload that was used to map to ProductData
         */
        private void removeFields() {
            this.fields.remove('B2B_IsProductSellable__c');
            this.fields.remove('B2B_IsLatest__c');
            this.fields.remove('B2B_Replaced_By__c');
            this.fields.remove('B2B_IsSaleCategoryProduct__c');
            this.fields.remove('B2B_UNITS__c');
            this.fields.remove('B2B_PACK_QUANTITY__c');
            this.fields.remove('B2B_LEAD_TIME__c');
            this.fields.remove('IsActive');
        }

