    /**
     * Inner class that will hold Part Supersession data.
     * This object will hold both older and newer parts.
     * For supersession chain product data and UI settings, check sellable flag.  If this flag is true, the product is
     * sellable and may show differently in the UI.
     * A Note on newerParts array.  This array will NOT hold the last, AKA the finalPart.  The FinalPart is exposed as
     * data elements on ProductData.
     * <p/>
     * - Field Definitions
     * - productId: String - The productId of the part for this product record
     * - sku: String - The product sku of the part for this product record
     * - sellable: Boolean - Flag to quickly determine if this product is sellable (true)
     * - inventoryAvailable: Decimal - How many of this product are available for purchase
     * - backorderable: Boolean - Flag to quickly determine if this product is backorderable (true)
     */
    public class PartSupersession {
        @AuraEnabled public String productId; //Id of the product
        @AuraEnabled public String sku;
        @AuraEnabled public Boolean sellable;
        @AuraEnabled public Decimal inventoryAvailable;
        @AuraEnabled public Boolean backorderable;
        @AuraEnabled public Boolean isActive;

        /**
         * Inline constructor to easily create a PartSupersession record.
         *
         * @param partNumberByText String
         * @param productId String
         * @param sku String
         * @param sellable Boolean
         * @param invAvail Decimal
         * @param backorderable Boolean
         * @param isActive Boolean
         */
        public PartSupersession(String partNumberByText, String productId, String sku, Boolean sellable, Decimal invAvail, Boolean backorderable, Boolean isActive) {
            this.productId = productId; // to fetch id of the product
            if (String.isBlank(sku)) {
                this.sku = partNumberByText;
            } else {
                this.sku = sku;
            }

            this.inventoryAvailable = invAvail;
            this.backorderable = backorderable;
            if (!sellable) {
                //if sellable is set as false, then set to false
                this.sellable = sellable;
            } else {
                //if sellable is set as true, check inventory level and backorderable flag
                this.sellable = (((invAvail > 0) && (backorderable == false)) || (backorderable));
            }
            //Check if the product is active or not when it not sellable
            if (!this.sellable && isActive == true) {
                this.isActive = isActive;
            } else {
                this.isActive = isActive;
            }
        }
    }

