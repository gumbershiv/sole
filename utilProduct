    /**
     * Maximum 500 products. Provide a list of product ids to return a List of ProductData.  This method will called components
     * to get product data, prices, media, inventory and sell-ability rules.
     * Will throw B2BException if more than 500 Skus are passed in.
     *
     * @param webstoreId String
     * @param effAccountId String
     * @param productIds List<String>
     * @param fields List<String>
     * @param excludeMedia Boolean
     * @param excludePricing Boolean
     * @param excludeSupersession Boolean
     *
     * @return List<ProductData>
     *
     * @throws B2BException Will be thrown when over 500 skus are given
     *
     * @see ScottB2BUtilProduct.ProductData
     */
    public static List<ProductData> getProductsById(
            String webstoreId,
            String effAccountId,
            List<Id> productIds,
            List<String> fields,
            Boolean excludeMedia,
            Boolean excludePricing,
            Boolean excludeSupersession) {

        if (Test.isRunningTest() && B2BUtilProductTest.testThrowException) {
            throw new B2BException('Test case wants an exception thrown!');
        }
        if (productIds.size() > 500) {
            B2BLoggingUtil.error('general_logger', 'B2BUtilProduct', 'getProductsById', 0, 'Maximum products exceeded.  500 is max, you sent ' + productIds.size(), null);
            B2BLoggingUtil.flush();
            throw new B2BException('Maximum products exceeded.  500 is max, you sent ' + productIds.size());
        }
        B2BUtil.B2BSessionInformation si = B2BUtil.getSessionInformation();
        system.debug('si......>'+si);
        String currencyCode = 'USD';
        if (B2BUtil.isGuest() || si == null || si.areFactorsCurrent == false || String.isEmpty(si.currencyCode)) {
            currencyCode = 'USD';
        } else {
            currencyCode = si.currencyCode;
        }


        fields = addNeededFieldsForProductLogic(fields);
        Map<Id, SolarProductInventory> productToInventoryMap = createInventoryMapNew(productIds, si.warehouseCode);

        List<ProductData> productDataList = new List<B2BUtilProduct.ProductData>();
        Map<Id, ProductData> productIdToProductData = new Map<Id, B2BUtilProduct.ProductData>();
        ConnectApi.PricingInput priceInput;
        if (!excludePricing) {
            priceInput = new ConnectApi.PricingInput();
            priceInput.pricingLineItems = new List<ConnectApi.PricingLineItemInput>();
        }
        List<String> originalSkuList = new List<String>((List<String>) productIds);
        List<String> workingSkuList = new List<String>((List<String>) productIds);
        Boolean moreIdsToProcess = true;
        while (moreIdsToProcess) {
            List<String> workingIds = new List<String>();
            if (workingSkuList.size() > 20) {
                for (Integer i = 1; i <= 20; i++) {
                    workingIds.add((String) workingSkuList.get(0));
                    workingSkuList.remove(0);
                }
            } else {
                workingIds = (List<String>) workingSkuList;
                moreIdsToProcess = false;
            }

//            Map<String, Object> prodOverviewCollectionUntyped;
            ConnectApi.ProductOverviewCollection prodOverviewCollection;
            if (Test.isRunningTest()) {
                //makeTestProductOverviewCollectionById method is created in B2BUtilProductTest class so that when we run the test class it fetches all data based on the ProductsIds
                prodOverviewCollection = B2BUtilProductTest.makeTestProductOverviewCollectionById(workingSkuList);
            } else {
                //prodOverviewCollectionUntyped = apiCommerceGetProducts(webstoreId, effAccountId, IdsOrSKus.ID, workingIds, fields, excludeMedia);
                prodOverviewCollection = commerceCatalogGetProducts(webstoreId, effAccountId, IdsOrSKus.ID, workingIds, fields, excludeMedia);
            }

            Set<Id> sellableProductIds = new Set<Id>();
            List<Object> apiBadOrNotSellableProducts = new List<Object>();
            //List<Object> apiProductOverviewList = (List<Object>)prodOverviewCollectionUntyped.get('products');

            for (ConnectApi.ProductOverview prodOverview : prodOverviewCollection.products) {
                //for (Object apiObjectProductOverview : apiProductOverviewList) {
                //Map<String, Object> apiProductOverview = (Map<String, Object>) apiObjectProductOverview;
                ProductData prodData = new ProductData(prodOverview);
                prodData.currencyCode = currencyCode;
                prodData = prodData.addInventoryDataNew(productToInventoryMap.get(prodData.id));
                if ((Boolean.valueOf(prodOverview.success) && (prodData.sellable))) {
                    if (!excludePricing) {
                        ConnectApi.PricingLineItemInput plii = new ConnectApi.PricingLineItemInput();
                        plii.productId = prodData.id;
                        priceInput.pricingLineItems.add(plii);
                    }
                    sellableProductIds.add(prodData.id);
                } else {
                    apiBadOrNotSellableProducts.add(prodOverview);
                }
                productDataList.add(prodData);
                productIdToProductData.put(prodData.id, prodData);
            }

            if (!excludePricing) {
                if (!priceInput.pricingLineItems.isEmpty()) {
                    ConnectApi.PricingResult priceResult;
                    if (Test.isRunningTest()) {
                        priceResult = B2BUtilProductTest.makeTestCommerceStorePricing();
                    } else {
                        priceResult = ConnectApi.CommerceStorePricing.getProductPrices(webstoreId, effAccountId, priceInput);
                    }
                    //todo - check priceResult.success
                    for (ConnectApi.PricingResultLineItem line : priceResult.pricingLineItemResults) {
                        ProductData pd = productIdToProductData.get(line.productId);
                        pd = pd.addPricingData(line, currencyCode);
                    }
                }
            }
        }

        if (!excludeSupersession) {
            B2BUtilProduct.addProductSupersessionData(productIdToProductData, originalSkuList);
        }
        productDataList = B2BUtilProduct.resolveFinalPartDatum(productDataList);
        return productDataList;
    }


    /**
     * Will use ConnectApi.CommerceSearch.searchProducts to search and find products.
     * Refer to Salesforce documentation on how to build input payload.  The return of pricing data
     * and supersession data is optional.  Set the appropriate flags.
     * The return wrapper will contain information from both the search call and ProductData to make
     * ordering decisions about each product.
     *
     * @param webstoreId String
     * @param effAccountId String
     * @param input ConnectApi.ProductSearchInput
     * @param excludePricing Boolean
     * @param excludeSupersession Boolean
     *
     * @return ScottB2BUtilProduct.ProductSearchWrapper
     *
     * @see ConnectApi.ProductSearchInput
     * @see ConnectApi.CommerceSearch.searchProducts
     * @see ScottB2BUtilProduct.ProductSearchWrapper
     */
    public static ProductSearchWrapper getProductsBySearch(
            String webstoreId,
            String effAccountId,
            ConnectApi.ProductSearchInput input,
            Boolean excludePricing,
            Boolean excludeSupersession) {
        if (Test.isRunningTest() && B2BUtilProductTest.testThrowException) {
            throw new B2BException('Test case wants an exception thrown!');
        }

        B2BUtil.B2BSessionInformation si = B2BUtil.getSessionInformation();
        String currencyCode = 'USD';
        if (B2BUtil.isGuest() || si == null || si.areFactorsCurrent == false || String.isEmpty(si.currencyCode)) {
            currencyCode = 'USD';
        } else {
            currencyCode = si.currencyCode;
        }

        input.fields = addNeededFieldsForProductLogic(input.fields);

        ConnectApi.ProductSearchResults result;
        ProductSearchWrapper psw = new ProductSearchWrapper();
        if (Test.isRunningTest()) {
            result = B2BUtilProductTest.makeTestProductSearchResults();
        } else {
            if (String.isNotBlank(input.searchTerm)) {
                //remove the sku: string, if present
                Boolean entitled;
                String productId;
                String cleansedSku = input.searchTerm.replace('sku:','').trim();
                List<Product2> prodBySkuSearch = [SELECT Id, StockKeepingUnit FROM Product2 WHERE StockKeepingUnit = :cleansedSku AND IsActive=TRUE];
                if ((!prodBySkuSearch.isEmpty()) && (prodBySkuSearch.size()==1)) {
                    input.searchTerm = ('sku:'+cleansedSku).toUpperCase();
                    psw.soloProductId = prodBySkuSearch.get(0).Id;
                    productId = prodBySkuSearch.get(0).Id;
                    //check entitlement
                    entitled = checkProductEntitled(webstoreId, effAccountId, productId);
                    if (!entitled){
                        psw.soloProductId = null;
                    }

                }
            }
            result = ConnectApi.CommerceSearch.searchProducts(webstoreId, effAccountId, input);
        }


        List<Id> productIds = new List<Id>();
        for (ConnectApi.ProductSummary ps : result.productsPage.products) {
            productIds.add(ps.id);
        }

        Map<Id, SolarProductInventory> productToInventoryMap = createInventoryMapNew(productIds, si.warehouseCode);

        List<ProductData> productDataList = new List<B2BUtilProduct.ProductData>();
        Map<Id, ProductData> productIdToProductData = new Map<Id, B2BUtilProduct.ProductData>();
        ConnectApi.PricingInput priceInput;
        if (!excludePricing) {
            priceInput = new ConnectApi.PricingInput();
            priceInput.pricingLineItems = new List<ConnectApi.PricingLineItemInput>();
        }
        List<String> originalSkuList = new List<String>((List<String>) productIds);

        Set<Id> sellableProductIds = new Set<Id>();
        List<ConnectApi.ProductSummary> badOrNotSellableProducts = new List<ConnectApi.ProductSummary>();

        for (ConnectApi.ProductSummary prodSummary : result.productsPage.products) {
            ProductData prodData = new ProductData(prodSummary);
            prodData = prodData.addInventoryDataNew(productToInventoryMap.get(prodSummary.id));
            if (prodData.sellable) {
                if (!excludePricing) {
                    ConnectApi.PricingLineItemInput plii = new ConnectApi.PricingLineItemInput();
                    plii.productId = prodSummary.id;
                    priceInput.pricingLineItems.add(plii);
                }
                sellableProductIds.add(prodSummary.id);
            } else {
                badOrNotSellableProducts.add(prodSummary);
            }
            productDataList.add(prodData);
            productIdToProductData.put(prodData.id, prodData);
        }

        if (!excludePricing) {
            if (!priceInput.pricingLineItems.isEmpty()) {
                ConnectApi.PricingResult priceResult;
                if (Test.isRunningTest()) {
                    priceResult = B2BUtilProductTest.makeTestCommerceStorePricing();
                } else {
                    priceResult = ConnectApi.CommerceStorePricing.getProductPrices(webstoreId, effAccountId, priceInput);
                }
                //todo - check priceResult.success
                for (ConnectApi.PricingResultLineItem line : priceResult.pricingLineItemResults) {
                    ProductData pd = productIdToProductData.get(line.productId);
                    pd = pd.addPricingData(line, currencyCode);
                }
            }
        }

        //need to figure out how to make this greater than 20.
        if (!excludeSupersession) {
            B2BUtilProduct.addProductSupersessionData(productIdToProductData, originalSkuList);
        }

        Map<Id, ProductData> mapIdToProdData = new Map<Id, B2BUtilProduct.ProductData>();
        for (ProductData pd : productDataList) {
            mapIdToProdData.put(pd.id, pd);
        }
        //build remainder of psw
        psw.searchResults = result;
        psw.productData = productDataList;
        psw.mapOfProductIdToProductData = mapIdToProdData;
        psw.productData = B2BUtilProduct.resolveFinalPartDatum(productDataList);

        return psw;
    }


    /**
     * Maximum 1 product. Provide an Id of product to return ProductData.  This method will call components
     * to get product data, inventory and sell-ability rules and supersession chain .
     *
     * @param productId Id
     *
     * @return ProductData
     *
     * @see ScottB2BUtilProduct.ProductData
     */
    @AuraEnabled
    public static ProductData getProductById(Id productId) {
        
        B2BUtil.B2BSessionInformation si = B2BUtil.getSessionInformation();

        Map<Id, SolarProductInventory> productToInventoryMap = createInventoryMapNew(new List<Id>{
                productId
        }, si.warehouseCode);

        ProductData productData;

        Product2 product = [
                SELECT Id,
                        B2B_IsProductSellable__c,
                        B2B_IsLatest__c,
                        B2B_Replaced_By__c,
                        B2B_IsSaleCategoryProduct__c,
                        B2B_UNITS__c,
                        B2B_PACK_QUANTITY__c,
                        B2B_LEAD_TIME__c,
                        StockKeepingUnit,
                        IsActive
                FROM Product2
                WHERE Id = :productId
        ];
        productData = new ProductData(product);
        productData = productData.addInventoryDataNew(productToInventoryMap.get(productId));

        Map<Id, ProductData> productIdToProductData = new Map<Id, B2BUtilProduct.ProductData>();
        productIdToProductData.put(productId, productData);

        List<ProductData> productDataList = new List<B2BUtilProduct.ProductData>{
                productData
        };
        B2BUtilProduct.addProductSupersessionData(productIdToProductData, new List<String>{
                productData.sku
        });
        productDataList = B2BUtilProduct.resolveFinalPartDatum(productDataList);
        return productDataList.get(0);
    }


