            }
            
            fields = addNeededFieldsForProductLogic(fields);
            List<ProductData> productDataList = new List<B2BUtilProduct.ProductData>();
            Map<Id, ProductData> productIdToProductData = new Map<Id, B2BUtilProduct.ProductData>();
            //Need to retain original sku list and create a working sku list
            //ConnectApi.getProducts only allows 20 records to be retrieved at a single time.
            //We need to repetitively make the call until all skus have been retrieved.
            //We will break the list down, 20 at a time.
            List<String> workingSkuList = new List<String>(skus);
            Boolean moreSkusToProcess = true;
            while (moreSkusToProcess) {
                List<String> workingSkus = new List<String>();
                if (workingSkuList.size() > 20) {
                    for (Integer i = 1; i <= 20; i++) {
                        workingSkus.add(workingSkuList.get(0));
