                for (Integer i = 1; i <= 20; i++) {
                    workingSkus.add(workingSkuList.get(0));
                    workingSkuList.remove(0);
                }
            } else {
                workingSkus = new List<String>(workingSkuList);
                moreSkusToProcess = false;
            }
            //Map<String, Object> prodOverviewCollectionUntyped;
            ConnectApi.ProductOverviewCollection prodOverviewCollection;
            if (Test.isRunningTest()) {
                //prodOverviewCollectionUntyped = B2BUtilProductTest.makeTestProductOverviewCollection(new List<String> {'T-1914970-1'});
                prodOverviewCollection = B2BUtilProductTest.makeTestProductOverviewCollection(workingSkuList);
