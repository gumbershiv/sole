                        priceResult = B2BUtilProductTest.makeTestCommerceStorePricing();
                    } else {
                        priceResult = ConnectApi.CommerceStorePricing.getProductPrices(webstoreId, effAccountId, priceInput);
                    }

                    for (ConnectApi.PricingResultLineItem line : priceResult.pricingLineItemResults) {
                        ProductData pd = productIdToProductData.get(line.productId);
                        pd = pd.addPricingData(line, currencyCode);
                    }
                }
            }
        }

        //Always get supersession data for package plp
        B2BUtilProduct.addProductSupersessionData(productIdToProductData, originalSkuList);
        productDataList = B2BUtilProduct.resolveFinalPartDatum(productDataList);

        Set<String> allSkus = new Set<String>(skuPartMap.keySet());

        Set<String> skusNotFound = new Set<String>(allSkus);

        skusNotFound.removeAll(skusFoundByConnectApi);

        Map<Id, ProductData> mapIdToProdData = new Map<Id, B2BUtilProduct.ProductData>();
        Map<String, ProductData> mapSkuToProdData = new Map<String, B2BUtilProduct.ProductData>();
        for (ProductData pd : productDataList) {

            if (String.isNotBlank(pd.id)) {
                mapIdToProdData.put(pd.id, pd);
                mapSkuToProdData.put(pd.sku, pd);
            }
        }
        List<ProductData> allPartsProductDataList = new List<B2BUtilProduct.ProductData>();
        for (B2B_PackagePart__c part : parts) {
            String partNumber = part.B2B_PartNumber__c;
            if (mapSkuToProdData.containsKey(partNumber)) {
                ProductData pd = mapSkuToProdData.get(partNumber);
                pd.packagePartQuantity = part.B2B_Quantity__c;
                pd.packagePartId = part.Id;
                pd.fields.put('Description', part.B2B_PartName__c.toLowerCase().capitalize());
                allPartsProductDataList.add(pd);
            } else {
                ProductData pd = new ProductData(partNumber);
                pd.packagePartQuantity = part.B2B_Quantity__c;
                pd.packagePartId = part.Id;
                pd.fields.put('Description', part.B2B_PartName__c.toLowerCase().capitalize());
                allPartsProductDataList.add(pd);
            }
        }

        Integer totalProductCount;
        CategoryContainer packageCategories = new CategoryContainer();
        Category category = new Category();
        packageCategories.children = new List<B2BUtilProduct.Children>();

        //Map<Id, Integer> systemCounts = new Map<Id, Integer>();
        Map<Id, Integer> subsystemCounts = new Map<Id, Integer>();
        List<B2B_Package__c> packageData;
        if (String.isBlank(input.systemOrSubsystemRefinement)) {
            //User is in Package
            category.description = 'All Systems';
            category.id = null;
            category.name = 'All Systems';
            category.urlName = null;
            packageCategories.category = category;

            String thePackageId = input.packageId;
            String partsWhere = '';
            if (String.isNotBlank(input.searchTerm)) {
                String srch = '%' + String.escapeSingleQuotes(input.searchTerm) + '%';
                partsWhere = ' AND (B2B_PartName__c LIKE :srch OR B2B_PartNumber__c LIKE :srch OR B2B_RefDes__c LIKE :srch) ';
            }
//            String soqlForPackageData =
//                    'SELECT Id, B2B_PackageLevel__c, B2B_Section__c, B2B_TotalPartsCount__c ' +
//                    'FROM B2B_Package__c ' +
//                    'WHERE B2B_PackageLevel__c = \'System\' AND B2B_HeaderId__r.Id = :thePackageId ';
            //+                     partsWhere;
            //packageData = Database.query(soqlForPackageData);

            packageData = [
                    SELECT Id, B2B_PackageLevel__c, B2B_Section__c, B2B_TotalPartsCount__c
                    FROM B2B_Package__c
                    WHERE B2B_PackageLevel__c = 'System' AND B2B_HeaderId__r.Id = :input.packageId
            ];


//            if (String.isNotBlank(partsWhere)) {
//                String soqlForPackageData =
//                        'SELECT COUNT(Id) numParts, B2B_PackageSystem__r.Id ' +
//                                'FROM B2B_PackagePart__c ' +
//                                'WHERE B2B_Package__r.Id = :thePackageId ' + partsWhere +
//                                ' GROUP BY B2B_PackageSystem__r.Id ';
//
//                List<AggregateResult> aggRes = Database.query(soqlForPackageData);
//
//                for (AggregateResult aggsRes : aggRes) {
//                    Id subSysId = (Id) aggsRes.get('Id');
//                    Integer numParts = (Integer) aggsRes.get('numParts');
//                    systemCounts.put(subSysId, numParts);
//                }
//            }




            String soqlForProductCount = 'SELECT COUNT() FROM B2B_PackagePart__c WHERE B2B_Package__r.Id = :thePackageId ' +
                    partsWhere;
            //totalProductCount = [SELECT COUNT() FROM B2B_PackagePart__c WHERE B2B_Package__r.Id = :input.packageId];

            totalProductCount = Database.countQuery(soqlForProductCount);
            packageCategories.productCount = totalProductCount;

            if (String.isNotBlank(partsWhere)) {
                //Clear out package list, we do not want a child to show up for searches
                packageData.clear();
            }

        } else {
            List<String> catParts = input.systemOrSubsystemRefinement.split('~');
            if(catParts != null){
                if (catParts.get(1).equalsIgnoreCase('System')) {
                    //User clicked on system
                    packageData = [
                            SELECT Id, B2B_PackageLevel__c, B2B_Section__c, B2B_TotalPartsCount__c, B2B_ParentSystem__r.B2B_Section__c
                            FROM B2B_Package__c
                            WHERE B2B_ParentSystem__r.Id = :catParts.get(0)
                    ];
                    for (AggregateResult aggRes : [
                            SELECT COUNT(Id) numParts, B2B_PackageSubSystem__r.Id
                            FROM B2B_PackagePart__c
                            WHERE B2B_PackageSystem__r.Id = :catParts.get(0)
                            GROUP BY B2B_PackageSubSystem__r.Id
                    ]) {
                        Id subSysId = (Id) aggRes.get('Id');
                        Integer numParts = (Integer) aggRes.get('numParts');
                        subsystemCounts.put(subSysId, numParts);
                    }
                    category.description = packageData.get(0).B2B_ParentSystem__r.B2B_Section__c;
                    category.id = null;
                    category.name = packageData.get(0).B2B_ParentSystem__r.B2B_Section__c;
                    category.urlName = null;
                    packageCategories.category = category;
                    totalProductCount = [SELECT COUNT() FROM B2B_PackagePart__c WHERE B2B_PackageSystem__r.Id = :catParts.get(0)];
                    packageCategories.productCount = totalProductCount;
                } else {
                    //User clicked on Subsystem
                    packageData = [
                            SELECT Id, B2B_PackageLevel__c, B2B_Section__c, B2B_TotalPartsCount__c, B2B_ParentSystem__r.B2B_Section__c
                            FROM B2B_Package__c
                            WHERE Id = :catParts.get(0)
                    ];
                    category.description = packageData.get(0).B2B_Section__c;
                    category.id = null;
                    category.name = packageData.get(0).B2B_Section__c;
                    category.urlName = null;
                    packageCategories.category = category;
                    totalProductCount = [SELECT COUNT() FROM B2B_PackagePart__c WHERE B2B_PackageSubSystem__r.Id = :catParts.get(0)];
                    packageCategories.productCount = totalProductCount;
                    //Clear out list, we do not want a child to show up for sub-systems
                    packageData.clear();
                }
            }

        }

        for (B2B_Package__c systems : packageData) {
            Children children = new Children();
            Category childCategory = new Category();
            childCategory.description = systems.B2B_Section__c;
            childCategory.id = systems.Id + '~' + systems.B2B_PackageLevel__c;
            childCategory.name = systems.B2B_Section__c;
            childCategory.urlName = null;
            if (subsystemCounts.isEmpty()) {
                children.productCount = Integer.valueOf(systems.B2B_TotalPartsCount__c);
            } else {
                children.productCount = subsystemCounts.get(systems.Id);
            }
//
//            if ((subsystemCounts==null) || (subsystemCounts.isEmpty())) {
//                if (String.isNotBlank(input.searchTerm)) {
//                    children.productCount = (systemCounts == null) ? 0 : (systemCounts.get(systems.Id) ?? 0);
//                } else {
//                    children.productCount = Integer.valueOf(systems.B2B_TotalPartsCount__c);
//                }
//            } else {
//                children.productCount = subsystemCounts.get(systems.Id) ?? 0;
//            }

            children.category = childCategory;
            children.children = new List<B2BUtilProduct.Children>();
            packageCategories.children.add(children);
        }

        List<Products> prods = new List<B2BUtilProduct.Products>();
        Integer i = 1;
        for (ProductData pData : allPartsProductDataList) {
            if (String.isBlank(pData.id)) {
                Products prod = new Products();
                prod.sequence = i;
                pData.sequence = i;
                prod.id = '';
                prod.packagePartId = pData.packagePartId;
                prod.name = pData.sku;
                prod.productData = pData;
                prods.add(prod);
            } else {
                Products prod = new Products();
                prod.id = pData.id;
                prod.packagePartId = pData.packagePartId;
                prod.sequence = i;
                pData.sequence = i;
                prod.name = pData.fields.get('Name');
                prod.productData = pData;
                prods.add(prod);
            }
            i++;
        }

        ProductPackageWrapper ppw = new ProductPackageWrapper();
        ppw.searchResults = new ProductDataForPackage();
        ppw.searchResults.locale = 'en_us';
        ppw.searchResults.productsPage = new ProductsPage();
        ppw.searchResults.productsPage.currencyIsoCode = currencyCode;
        ppw.searchResults.productsPage.products = prods;
        ppw.searchResults.productsPage.total = totalProductCount;
        ppw.searchResults.categories = packageCategories;

        ppw.productData = allPartsProductDataList;
        ppw.mapOfProductIdToProductData = mapIdToProdData;

        system.debug('End Return@@'+ppw);
        return ppw;

    }


    /**
     * Provide a list of product2 records to return a List of bare bone minimum ProductData.  This method will call components
     * to get only basic product data and final part dataum.  This can be used to determine if a part has any final part
     * and if the current and/or final parts are sellable.  This method will not call any ConnectApi methods.
     *
     * @param products List<Product2> List of products to get data for
     *
     * @return List<ProductData>
     *
     * @see ScottB2BUtilProduct.ProductData
     */
    public static List<ProductData> getProductDataNoFrillsByProduct2(List<Product2> products) {
        List<String> productIds = new List<String>();
        for (Product2 prod : products) {
            productIds.add(prod.Id);
        }
        B2BUtil.B2BSessionInformation si = B2BUtil.getSessionInformation();

        Map<Id, SolarProductInventory> productToInventoryMap = createInventoryMapNew(productIds, si.warehouseCode);

        List<ProductData> productDataList = new List<B2BUtilProduct.ProductData>();
        Map<Id, ProductData> productIdToProductData = new Map<Id, B2BUtilProduct.ProductData>();

        Set<Id> sellableProductIds = new Set<Id>();
        List<Object> apiBadOrNotSellableProducts = new List<Object>();

        for (Product2 prod : products) {
            ProductData prodData = new ProductData(prod);
            prodData = prodData.addInventoryDataNew(productToInventoryMap.get(prodData.id));
            if (prodData.sellable) {
                sellableProductIds.add(prodData.id);
            } else {
                apiBadOrNotSellableProducts.add(prod);
            }
            productDataList.add(prodData);
            productIdToProductData.put(prodData.id, prodData);
        }

        productDataList = B2BUtilProduct.resolveFinalPartDatum(productDataList);
        return productDataList;
    }

    /**
     * @description Takes one product and will determine if it is entitled to the webstore and account.
     *
     * @param webstoreId String (Id)
     * @param effectiveAccountId String (Id)
     * @param productId String (Id)
     *
     * @return Boolean true if product is found and entitled, otherwise false
     */
    public static Boolean checkProductEntitled(String webstoreId, String effectiveAccountId, String productId) {
        Boolean result = false;
        try {
            //Will throw an exception if the product is not entitled or found
            ConnectApi.CommerceCatalog.getProduct(
                    webstoreId, productId, effectiveAccountId ,null,
                    null, true,true,true,true,true,true,true,'false'
            );
            result = true;
        } catch (ConnectApi.NotFoundException noProduct) {
            result = false;
        }
        return result;
    }

