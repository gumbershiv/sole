            ProductPackageSearchInput input) {

        String sortDirection = String.isNotBlank(input.direction) ? input.direction : 'ASC';
        Map<String, List<B2B_PackagePart__c>> skuPartMap = new Map<String, List<B2B_PackagePart__c>>();
        String partsQuery;

        //making SystemorSubSystem value blank so that input search term data returns on the package level
        if(String.isNotBlank(input.searchTerm)) {
            input.systemOrSubsystemRefinement = '';
        }

        if (String.isBlank(input.systemOrSubsystemRefinement) || String.isNotBlank(input.searchTerm)) {
            //We are either at the package level or user has entered a search term
            String thePackageId = input.packageId;
            String partsWhere = '';
            if (String.isNotBlank(input.searchTerm)) {
                String srch = '%' + String.escapeSingleQuotes(input.searchTerm) + '%';
                partsWhere = ' AND (B2B_PartName__c LIKE :srch OR B2B_PartNumber__c LIKE :srch OR B2B_RefDes__c LIKE :srch) ';
            }
            partsQuery = 'SELECT B2B_Callout__c, B2B_ExternalId__c, B2B_Package__c, B2B_PackageSubSystem__c, B2B_PackageSystem__c, ' +
                    '        B2B_PartName__c,B2B_PartNumber__c, B2B_Product__c, B2B_Quantity__c, B2B_RefDes__c, ' +
