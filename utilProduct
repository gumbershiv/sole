    /**
     * Will run through skusOrIds to find all older and all newer parts and build lists to attach to the ProductData.
     *
     * @param productIdToProductData Map<Id, ProductData>
     * @param skusOrIds List<String>
     *
     * @see ScottB2BUtilProduct.PartSupersession
     */
    @TestVisible
    private static void addProductSupersessionData(Map<Id, ProductData> productIdToProductData, List<String> skusOrIds) {
        //Query to get the older parts in the chain
        //Add to map to retrieve later by ProductId of current Part, with List of older parts in order
        Set<String> skusToGetInventoryFor = new Set<String>();
        Map<Id, List<ProductSupersessionChain__c>> productToSuperOlderMap = new Map<Id, List<ProductSupersessionChain__c>>();
        for (ProductSupersessionChain__c supersession : [
                SELECT Id, ReplacedBy__r.StockKeepingUnit, ReplacedProduct__r.StockKeepingUnit,
                        ReplacedProduct__r.IsActive, ReplacedProduct__r.B2B_IsProductSellable__c,
                        ReplacedByText__c, ReplacedProductText__c
                FROM ProductSupersessionChain__c
                WHERE (ReplacedBy__r.Id IN :skusOrIds OR ReplacedBy__r.StockKeepingUnit IN :skusOrIds)
                ORDER BY Sequence__c, ReplacedProduct__r.StockKeepingUnit DESC
        ]) {
            if (!productToSuperOlderMap.containsKey(supersession.ReplacedBy__c)) {
                productToSuperOlderMap.put(supersession.ReplacedBy__c, new List<ProductSupersessionChain__c>());
            }
            productToSuperOlderMap.get(supersession.ReplacedBy__c).add(supersession);
            if (supersession.ReplacedProduct__r.IsActive || supersession.ReplacedProduct__r.B2B_IsProductSellable__c) {
                skusToGetInventoryFor.add(supersession.ReplacedProduct__r.StockKeepingUnit);
            }
        }

        //Query to get the newer parts in the chain
        //Add to map to retrieve later by ProductId of current Part, with List of newer parts in order
        Map<Id, List<ProductSupersessionChain__c>> productToSuperNewerMap = new Map<Id, List<ProductSupersessionChain__c>>();
        for (ProductSupersessionChain__c supersession : [
                SELECT Id, ReplacedBy__r.StockKeepingUnit, ReplacedProduct__r.StockKeepingUnit, ReplacedBy__r.B2B_Replaced_By__c, ReplacedProduct__r.B2B_Replaced_By__c,
                        ReplacedBy__r.IsActive, ReplacedBy__r.B2B_IsProductSellable__c,
                        ReplacedByText__c, ReplacedProductText__c
                FROM ProductSupersessionChain__c
                WHERE (ReplacedProduct__r.Id IN :skusOrIds OR ReplacedProduct__r.StockKeepingUnit IN :skusOrIds)
                ORDER BY Sequence__c, ReplacedProduct__r.StockKeepingUnit DESC
        ]) {

            if ((String.isNotBlank(supersession.ReplacedBy__r.StockKeepingUnit) &&
                    (supersession.ReplacedBy__r.StockKeepingUnit != supersession.ReplacedProduct__r.B2B_Replaced_By__c))) {
                if (!productToSuperNewerMap.containsKey(supersession.ReplacedProduct__c)) {
                    productToSuperNewerMap.put(supersession.ReplacedProduct__c, new List<ProductSupersessionChain__c>());
                }
                productToSuperNewerMap.get(supersession.ReplacedProduct__c).add(supersession);
                if (supersession.ReplacedBy__r.IsActive || supersession.ReplacedBy__r.B2B_IsProductSellable__c) {
                    skusToGetInventoryFor.add(supersession.ReplacedBy__r.StockKeepingUnit);
                }
            }
        }
        
        B2BUtil.B2BSessionInformation si = B2BUtil.getSessionInformation();
        
        //Need to get inventory for supersession parts
        Map<Id, SolarProductInventory> productToInventoryMap = createInventoryMapNew(new List<String>(skusToGetInventoryFor),si.warehouseCode);

        //merge inventory and basic product information to build "Older Parts" List
        for (ProductData pd : productIdToProductData.values()) {
            if (!productToSuperOlderMap.isEmpty() && productToSuperOlderMap.containsKey(pd.id)) {
                for (ProductSupersessionChain__c psc : productToSuperOlderMap.get(pd.id)) {
                    if (pd.olderParts == null) {
                        pd.olderParts = new List<B2BUtilProduct.PartSupersession>();
                    }
                    SolarProductInventory inv = productToInventoryMap.get(psc.ReplacedProduct__c);
                    if (inv == null) {
                        pd.olderParts.add(new PartSupersession(psc.ReplacedProductText__c, psc.ReplacedProduct__c, psc.ReplacedProduct__r.StockKeepingUnit, psc.ReplacedProduct__r.B2B_IsProductSellable__c, 0, false, psc.ReplacedProduct__r.IsActive));
                    } else {
                        pd.olderParts.add(new PartSupersession(psc.ReplacedProductText__c, psc.ReplacedProduct__c, psc.ReplacedProduct__r.StockKeepingUnit, psc.ReplacedProduct__r.B2B_IsProductSellable__c, inv.globalWarehouseInventory, inv.allowBackOrder, psc.ReplacedProduct__r.IsActive));
                    }
                }
            }
        }

        //merge inventory and basic product information to build "Newer Parts" List
        for (ProductData pd : productIdToProductData.values()) {
            if (!productToSuperNewerMap.isEmpty() && productToSuperNewerMap.containsKey(pd.id)) {
                for (ProductSupersessionChain__c psc : productToSuperNewerMap.get(pd.id)) {
                    if (pd.newParts == null) {
                        pd.newParts = new List<B2BUtilProduct.PartSupersession>();
                    }
                    SolarProductInventory inv = productToInventoryMap.get(psc.ReplacedBy__c);
                    if (inv == null) {
                        pd.newParts.add(new PartSupersession(psc.ReplacedByText__c, psc.ReplacedBy__c, psc.ReplacedBy__r.StockKeepingUnit, psc.ReplacedBy__r.B2B_IsProductSellable__c, 0, false, psc.ReplacedBy__r.IsActive));
                    } else {
                        pd.newParts.add(new PartSupersession(psc.ReplacedByText__c, psc.ReplacedBy__c, psc.ReplacedBy__r.StockKeepingUnit, psc.ReplacedBy__r.B2B_IsProductSellable__c, inv.globalWarehouseInventory, inv.allowBackOrder, psc.ReplacedBy__r.IsActive));
                    }
                }
            }
        }
    }


    /**
     * Maximum 500 products. Provide a list of SKUs to return a List of ProductData.  This method will called components
     * to get product data, prices, media, inventory and sell-ability rules.
     * Will throw B2BException if more than 500 Skus are passed in.
     *
     * @param webstoreId String
     * @param effAccountId String
     * @param skus List<String>
     * @param fields List<String>
     * @param excludeMedia Boolean
     * @param excludePricing Boolean
     * @param excludeSupersession Boolean
     *
     * @return List<ProductData>
     *
     * @throws B2BException Will be thrown when over 500 skus are given
     *
     * @see ScottB2BUtilProduct.ProductData
     */
    public static List<ProductData> getProductsBySku(
            String webstoreId,
            String effAccountId,
            List<String> skus,
            List<String> fields,
            Boolean excludeMedia,
            Boolean excludePricing,
            Boolean excludeSupersession) {
        if (Test.isRunningTest() && B2BUtilProductTest.testThrowException) {
            throw new B2BException('Test case wants an exception thrown!');
        }
        if (skus.size() > 500) {
            B2BLoggingUtil.error('general_logger', 'B2BUtilProduct', 'getProductsBySku', 0, 'Maximum products exceeded.  500 is max, you sent ' + skus.size(), null);
            B2BLoggingUtil.flush();
            throw new B2BException('Maximum products exceeded.  500 is max, you sent ' + skus.size());
        }
        B2BUtil.B2BSessionInformation si = B2BUtil.getSessionInformation();
        system.debug('s......>i'+si);

        // we can fetch warehouse from si
        String currencyCode = 'USD';
        if (B2BUtil.isGuest() || si == null || si.areFactorsCurrent == false || String.isEmpty(si.currencyCode)) {
            currencyCode = 'USD';
        } else {
            currencyCode = si.currencyCode;
        }

        fields = addNeededFieldsForProductLogic(fields);
        Map<Id, SolarProductInventory> productToInventoryMap = createInventoryMapNew(skus, si.warehouseCode);
        List<ProductData> productDataList = new List<B2BUtilProduct.ProductData>();
        Map<Id, ProductData> productIdToProductData = new Map<Id, B2BUtilProduct.ProductData>();
        ConnectApi.PricingInput priceInput;
        if (!excludePricing) {
            //instantiates pricing input objects.
            priceInput = new ConnectApi.PricingInput();
            priceInput.pricingLineItems = new List<ConnectApi.PricingLineItemInput>();
        }
        //Need to retain original sku list and create a working sku list
        //ConnectApi.getProducts only allows 20 records to be retrieved at a single time.
        //We need to repetitively make the call until all skus have been retrieved.
        //We will break the list down, 20 at a time.
        List<String> originalSkuList = new List<String>(skus);
        List<String> workingSkuList = new List<String>(skus);
        Boolean moreSkusToProcess = true;
        while (moreSkusToProcess) {
            List<String> workingSkus = new List<String>();
            if (workingSkuList.size() > 20) {
                for (Integer i = 1; i <= 20; i++) {
                    workingSkus.add(workingSkuList.get(0));
                    workingSkuList.remove(0);
                }
            } else {
                workingSkus = new List<String>(workingSkuList);
                moreSkusToProcess = false;
            }
            //Map<String, Object> prodOverviewCollectionUntyped;
            ConnectApi.ProductOverviewCollection prodOverviewCollection;
            if (Test.isRunningTest()) {
                //prodOverviewCollectionUntyped = B2BUtilProductTest.makeTestProductOverviewCollection(workingSkuList);
                prodOverviewCollection = B2BUtilProductTest.makeTestProductOverviewCollection(workingSkuList);

            } else {
                //prodOverviewCollectionUntyped = apiCommerceGetProducts(webstoreId, effAccountId, IdsOrSKus.SKU, workingSkus, fields, excludeMedia);
                prodOverviewCollection = commerceCatalogGetProducts(webstoreId, effAccountId, IdsOrSKus.SKU, workingSkus, fields, excludeMedia);
            }

            Set<Id> sellableProductIds = new Set<Id>();
            List<Object> apiBadOrNotSellableProducts = new List<Object>();
            //List<Object> apiProductOverviewList = (List<Object>)prodOverviewCollectionUntyped.get('products');

            for (ConnectApi.ProductOverview prodOverview : prodOverviewCollection.products) {
                //for (Object apiObjectProductOverview : apiProductOverviewList) {
                //Map<String, Object> apiProductOverview = (Map<String, Object>) apiObjectProductOverview;
                ProductData prodData = new ProductData(prodOverview);
                prodData.currencyCode = currencyCode;
                prodData = prodData.addInventoryDataNew(productToInventoryMap.get(prodData.id));
                if ((Boolean.valueOf(prodOverview.success) && (prodData.sellable))) {
                    if (!excludePricing) {
                        ConnectApi.PricingLineItemInput plii = new ConnectApi.PricingLineItemInput();
                        plii.productId = prodData.id;
                        priceInput.pricingLineItems.add(plii);
                    }
                    sellableProductIds.add(prodData.id);
                } else {
                    apiBadOrNotSellableProducts.add(prodOverview);
                }
                productDataList.add(prodData);
                productIdToProductData.put(prodData.id, prodData);
            }

            if (!excludePricing) {
                if (!priceInput.pricingLineItems.isEmpty()) {
                    ConnectApi.PricingResult priceResult;
                    if (Test.isRunningTest()) {
                        priceResult = B2BUtilProductTest.makeTestCommerceStorePricing();
                    } else {
                        priceResult = ConnectApi.CommerceStorePricing.getProductPrices(webstoreId, effAccountId, priceInput);
                    }

                    //todo - check priceResult.success
                    for (ConnectApi.PricingResultLineItem line : priceResult.pricingLineItemResults) {
                        ProductData pd = productIdToProductData.get(line.productId);
                        pd = pd.addPricingData(line, currencyCode);
                    }
                }
            }
        }

        if (!excludeSupersession) {
            B2BUtilProduct.addProductSupersessionData(productIdToProductData, originalSkuList);
        }
        productDataList = B2BUtilProduct.resolveFinalPartDatum(productDataList);
        return productDataList;
    }
    
