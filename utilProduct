        /**
         * Using the incoming B2B_ProductInventory__c will add/update the data od ProductData to set the correct
         * property values and messages around inventory data and its impacts to product availability and sell-ability.
         *
         * @param invData B2B_ProductInventory__c The current inventory record for the current product.
         *
         * @return ProductData Updated ProductData record for inventory related decisions
         *
         * @see B2B_ProductInventory__c
         */
        public ProductData addInventoryData(B2B_ProductInventory__c invData) {
            System.debug('DEBUG → invData addInventoryData: ' + invData);
            if (invData != null) {
                this.stockStatus = invData.B2B_Status__c;
                this.instock = invData.B2B_InventoryAvailableInSalesUOM__c > 0;
                this.backorderable = invData.B2B_AllowBackOrders__c;
                this.inventoryAvailable = invData.B2B_InventoryAvailableInSalesUOM__c;
                if (!this.instock) {
                    //todo PageLabel
                    this.leadTime = 'Lead time up to ' + this.leadTime + ' business days';
                }
                if ((!this.instock) && (!this.backorderable)) {
                    this.sellable = false;
                }

                if (this.sellable) {
                    if (this.backorderable) {
                        this.purchaseLimit = 99999;  //TODO Custom Metadata
                    } else {
                        this.purchaseLimit = this.inventoryAvailable;
                    }
                } else {
                    this.purchaseLimit = 0;
                }
            } else {
                this.stockStatus = 'Out of Stock';
                this.instock = false;
                //this.backorderable = invData.B2B_AllowBackOrders__c;
                this.inventoryAvailable = 0;
                this.sellable = false;
                this.purchaseLimit = 0;
            }
            return this;
        }


        public ProductData addInventoryDataNew(SolarProductInventory invData) {
            if (invData != null) {
                //this.instock = invData.globalWarehouseInventory > 0;

                //this.backorderable = invData.allowBackOrder;

                if ((invData.globalWarehouseInventory<=0) && (!invData.allowBackOrder)) {
                    this.sellable = false;
                } else {
                    this.sellable = true;
                }

                if ((invData.allowBackOrder) && (invData.currentWarehouseInventory>0)) {
                    invData.currentWarehouseStatus = 'In Stock';
                } else if ((invData.allowBackOrder) && (invData.currentWarehouseInventory<=0)) {
                    invData.currentWarehouseStatus = 'Out of Stock';
                } else if ((!invData.allowBackOrder) && (invData.currentWarehouseInventory>0)) {
                    invData.currentWarehouseStatus = 'Limited Availability';
                } else if ((!invData.allowBackOrder) && (invData.currentWarehouseInventory<=0)) {
                    invData.currentWarehouseStatus = 'Unavailable';
                }

                if ((invData.allowBackOrder) && (invData.otherWarehouseInventory>0)) {
                    invData.otherWarehouseStatus = 'In Stock';
                } else if ((invData.allowBackOrder) && (invData.otherWarehouseInventory<=0)) {
                    invData.otherWarehouseStatus = 'Out of Stock';
                } else if ((!invData.allowBackOrder) && (invData.otherWarehouseInventory>0)) {
                    invData.otherWarehouseStatus = 'Limited Availability';
                } else if ((!invData.allowBackOrder) && (invData.otherWarehouseInventory<=0)) {
                    invData.otherWarehouseStatus = 'Unavailable';
                }
                if (this.sellable) {

                    if (invData.allowBackOrder) {
                        invData.purchaseLimit = 99999;  //TODO Custom Metadata
                    } else {
                        invData.purchaseLimit = invData.globalWarehouseInventory;
                    }
                } else {
                    invData.purchaseLimit = 0;
                }
            } else {
                //this.stockStatus = 'Out of Stock';
                //this.instock = false;
                //this.backorderable = invData.B2B_AllowBackOrders__c;
                invData.currentWarehouseStatus = invData.allowBackOrder ? 'Out of Stock' : 'Unavailable';
                invData.otherWarehouseStatus = invData.allowBackOrder ? 'Out of Stock' : 'Unavailable';
                this.sellable = false;
                invData.globalWarehouseInventory = 0;
                invData.currentWarehouseInventory = 0;
                this.purchaseLimit = 0;
            }
            this.inventory = invData;
            return this;
        }





