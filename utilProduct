    /**
     * In order to make sell-ability decisions, certain product data must be retrieved.  Once populated on Product Data
     * These fields no longer need to be part of the Fields payload.  Also each person using this utility does not need
     * to know all of the field names or add them to their query.  This will add the needed fields for the ConnectApi
     * to use.
     *
     * @param fields List<String> The fields originally requested by the caller.
     *
     * @return List<String> The new set of fields, included the needed ones to build ProductData
     */
    @TestVisible
    private static List<String> addNeededFieldsForProductLogic(List<String> fields) {
        if (fields == null) {
            fields = new List<String>();
        }
        if (!fields.contains('B2B_IsProductSellable__c')) fields.add('B2B_IsProductSellable__c');
        if (!fields.contains('B2B_IsLatest__c')) fields.add('B2B_IsLatest__c');
        if (!fields.contains('B2B_Replaced_By__c')) fields.add('B2B_Replaced_By__c');
        if (!fields.contains('B2B_IsSaleCategoryProduct__c')) fields.add('B2B_IsSaleCategoryProduct__c');
        if (!fields.contains('B2B_UNITS__c')) fields.add('B2B_UNITS__c');
        if (!fields.contains('B2B_PACK_QUANTITY__c')) fields.add('B2B_PACK_QUANTITY__c');
        if (!fields.contains('B2B_LEAD_TIME__c')) fields.add('B2B_LEAD_TIME__c');
        if (!fields.contains('StockKeepingUnit')) fields.add('StockKeepingUnit');
        if (!fields.contains('IsActive')) fields.add('IsActive');
        if (!fields.contains('B2B_Info_Code__c')) fields.add('B2B_Info_Code__c');
        return fields;
    }

    /**
     * Once all of the ProductData elements are assembled, need to run through all parts that have a finalPart set.
     * finalPart is the SKU.  Using the finalPart SKU, find the correct product id for the SKU and then set finalPartId.
     * This will also get the finalPartPurchaseLimit for that finalPart.
     *
     * @param productDataList List<ProductData>  List of ProductData that may need to have finalParts resolved for Ids.
     *
     * @return List<ProductData> Updated List with the finalPartId
     */
    @SuppressWarnings('PMD.AvoidDeeplyNestedIfStmts') //Complex logic to support Solar product orderability rules and supersession chains.
    public static List<ProductData> resolveFinalPartDatum(List<ProductData> productDataList) {
        if (!FINAL_PART_SET_FOR_ID_RETRIEVAL.isEmpty()) {
            //Build map of final part skus with their product inventories
            //MLP we will only be supporting UDQS10 warehouse
            //TODO With multiple warehouse processing, this will need to be updated to select proper warehouse
            //TODO ddd
            //TODO ddd
            Map<String, AggregateResult> productSkuToProductInventory = new Map<String, AggregateResult>();
            for (AggregateResult productInvSum : [
                    SELECT B2B_Product__c, B2B_Product__r.StockKeepingUnit, B2B_Product__r.B2B_IsProductSellable__c, SUM(B2B_InventoryAvailableInSalesUOM__c), B2B_AllowBackOrders__c
                    FROM B2B_ProductInventory__c
                    WHERE B2B_Product__r.StockKeepingUnit IN :FINAL_PART_SET_FOR_ID_RETRIEVAL
                    GROUP BY B2B_Product__c, B2B_Product__r.StockKeepingUnit, B2B_Product__r.B2B_IsProductSellable__c, B2B_AllowBackOrders__c
            ]) {
                productSkuToProductInventory.put((String)productInvSum.get('StockKeepingUnit'), productInvSum);
            }
            for (ProductData pd : productDataList) {
                if (String.isNotBlank(pd.finalPart)) {
                    AggregateResult productInv = productSkuToProductInventory.get(pd.finalPart);
                    if (productInv != null) {
                        pd.finalPartId = (String) productInv.get('B2B_Product__c');
                        pd.finalPartPurchaseLimit = (Boolean) productInv.get('B2B_AllowBackOrders__c') ? 99999 : (Decimal)productInv.get('expr0');
                        //Make finalpart not sellable by setting Id to null and purchaselimit to 0
                        if (!(Boolean) productInv.get('B2B_IsProductSellable__c')) {
                            pd.finalPartId = null;
                            pd.finalPartPurchaseLimit = 0;
                        }
                    } else {
                        pd.finalPartId = null;
                        pd.finalPartPurchaseLimit = 0;
                    }
                }
            }
        }
        return productDataList;

    }
    /**
     * Takes a list of product skus OR list of product ids and returns a map.
     * The Map will have the Product2 Id as the key and the value will be the corresponding inventory record.
     *
     * @param skusOrIds List<String> of product skus or product ids to get inventory for
     *
     * @return Map<Id, B2B_ProductInventory__c>
     *
     * @see B2B_ProductInventory__c
     */
    @SuppressWarnings('PMD.EmptyCatchBlock')
    @TestVisible
    private static Map<Id, B2B_ProductInventory__c> createInventoryMap(List<String> skusOrIds) {
        Set<String> localSkusOrIds = new Set<String>(skusOrIds);  //create Local list to prevent mutation of list back to caller
        //MLP we will only be supporting UDQS10 warehouse
        //TODO With multiple warehouse processing, this will need to be updated to select proper warehouse
        Map<Id, B2B_ProductInventory__c> productToInventoryMap = new Map<Id, B2B_ProductInventory__c>();
        for (B2B_ProductInventory__c inv : [
                SELECT
                        B2B_AllowBackOrders__c,
                        B2B_InventoryAvailableInSalesUOM__c,
                        B2B_Status__c,
                        B2B_Product__c,
                        B2B_Product__r.StockKeepingUnit,
                        Id
                FROM B2B_ProductInventory__c
                WHERE (B2B_Product__r.StockKeepingUnit IN :skusOrIds OR B2B_Product__r.Id IN :skusOrIds)
                AND B2B_Warehouse__c = 'UDQS10'
        ]) {
            productToInventoryMap.put(inv.B2B_Product__c, inv);
            localSkusOrIds.remove(String.valueOf(inv.B2B_Product__c));
            localSkusOrIds.remove(inv.B2B_Product__r.StockKeepingUnit);
        }
        for (Product2 p : [
                SELECT Id, StockKeepingUnit
                FROM Product2
                WHERE (StockKeepingUnit IN :localSkusOrIds OR Id IN :localSkusOrIds)
        ]) {
            productToInventoryMap.put(p.Id, new B2B_ProductInventory__c(B2B_InventoryAllocated__c = 0, B2B_InventoryOnHand__c = 0, B2B_InventoryOnOrder__c = 0));
            localSkusOrIds.remove(String.valueOf(p.Id));
            localSkusOrIds.remove(p.StockKeepingUnit);
        }
        for (String key : localSkusOrIds) {
            try {
                Id pId = (Id) key;
                if (!productToInventoryMap.containsKey(key)) {
                    productToInventoryMap.put(pId, new B2B_ProductInventory__c(B2B_InventoryAllocated__c = 0, B2B_InventoryOnHand__c = 0, B2B_InventoryOnOrder__c = 0));
                }
            } catch (Exception e) {
                //do nothing.  An exception may occur due to the combination of SKUs and Ids.  Salesforce does not like when you use a sku as an ID.
                //Exceptions are expected and it is ok to ignore them here.
            }
        }
        return productToInventoryMap;
    }

    /**
     * Takes a list of product skus OR list of product ids and returns a map.
     * The Map will have the Product2 Id as the key and the value will be the corresponding inventory record.
     *
     * @param skusOrIds List<String> of product skus or product ids to get inventory for
     *
     * @return Map<Id, B2B_ProductInventory__c>
     *
     * @see ScottB2BUtilProduct.SolarProductInventory
     */
    @SuppressWarnings('PMD.EmptyCatchBlock')
    @TestVisible
    private static Map<Id, SolarProductInventory> createInventoryMapNew(List<String> skusOrIds, String currentWarehouse) {
        Set<String> localSkusOrIds = new Set<String>(skusOrIds);  //create Local list to prevent mutation of list back to caller
        /* Things we need...
           Current Warehouse Code
           Inventory in current warehouse  (localInventory)
           Lead Time at current warehouse
           Inventory sum of other warehouses (otherInventory)
           Sum of all warehouses (globalInventory)
           B2B_AllowBackOrders__c
           B2B_Status__c
           B2B_Product__c
           B2B_Product__r.StockKeepingUnit
         */

        //MLP we will only be supporting UDQS10 warehouse
        //TODO With multiple warehouse processing, this will need to be updated to select proper warehouse
        Map<Id, B2B_ProductInventory__c> productToInventoryMapOrig = new Map<Id, B2B_ProductInventory__c>();
        Map<Id, SolarProductInventory> productToInventoryMap = new Map<Id, SolarProductInventory>();
        //String currentWarehouse = 'UDQS10';
        for (B2B_ProductInventory__c inv : [
                SELECT
                        B2B_AllowBackOrders__c,
                        B2B_InventoryAvailableInSalesUOM__c,
                        B2B_Status__c,
                        B2B_Product__c,
                        B2B_Product__r.StockKeepingUnit,
            			B2B_Product__r.B2B_LEAD_TIME__c,
                        B2B_Warehouse__c,
                        Id
                FROM B2B_ProductInventory__c
                WHERE (B2B_Product__r.StockKeepingUnit IN :skusOrIds OR B2B_Product__r.Id IN :skusOrIds)
                //AND B2B_Warehouse__c = 'UDQS10'
        ]) {
            
            B2B_StoreSetting__mdt storeSetting = B2B_StoreSetting__mdt.getInstance('ShopSolar');
            String usWarehouseCode = storeSetting.B2B_UnitedStatesWarehouseCode__c;
            Integer additionalLeadTime = storeSetting.B2B_additionalLeadTime__c != null ? Integer.valueOf(storeSetting.B2B_additionalLeadTime__c) : 0;
            Integer currentWarehouseLeadTime = inv.B2B_Product__r.B2B_LEAD_TIME__c != null ? Integer.valueOf(inv.B2B_Product__r.B2B_LEAD_TIME__c) : 0 ;
            
            if (productToInventoryMap.containsKey(inv.B2B_Product__c)) {
                SolarProductInventory pi = productToInventoryMap.get(inv.B2B_Product__c);
                if (inv.B2B_Warehouse__c == currentWarehouse) {
                    pi.currentWarehouseCode = inv.B2B_Warehouse__c;
                    pi.currentWarehouseInventory = Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c);
                    if(currentWarehouse == usWarehouseCode){
                        pi.currentWarehouseLeadTime = currentWarehouseLeadTime;
                    }else{
                        pi.currentWarehouseLeadTime = currentWarehouseLeadTime + additionalLeadTime;
                    }
                    //pi.currentWarehouseLeadTime = Integer.valueOf(inv.B2B_WarehouseLeadTime__c);
                } else {
                    if((Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c)) > 0){
                        pi.globalWarehouseInventory += Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c);
                    }
                }
                if((Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c)) > 0){
                    pi.globalWarehouseInventory += Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c);
                }
            } else {
                SolarProductInventory pi = new SolarProductInventory();
                if (inv.B2B_Warehouse__c == currentWarehouse) {
                    pi.currentWarehouseCode = inv.B2B_Warehouse__c;
                    pi.currentWarehouseInventory = Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c);
                    //pi.currentWarehouseLeadTime = Integer.valueOf(inv.B2B_WarehouseLeadTime__c);
                    pi.currentWarehouseStatus = inv.B2B_Status__c;
                    if(currentWarehouse == usWarehouseCode){
                        pi.currentWarehouseLeadTime = currentWarehouseLeadTime;
                    }else{
                        pi.currentWarehouseLeadTime = currentWarehouseLeadTime + additionalLeadTime;
                    }
                    
                } else {
                    pi.otherWarehouseInventory += Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c);
                    pi.otherWarehouseStatus = inv.B2B_Status__c;
                }
                pi.globalWarehouseInventory = Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c) > 0 ? Integer.valueOf(inv.B2B_InventoryAvailableInSalesUOM__c) : 0;
                pi.productId = inv.B2B_Product__c;
                pi.allowBackOrder = inv.B2B_AllowBackOrders__c;
                pi.productSku = inv.B2B_Product__r.StockKeepingUnit;

                productToInventoryMap.put(inv.B2B_Product__c, pi);
            }
            //productToInventoryMap.put(inv.B2B_Product__c, inv);
            localSkusOrIds.remove(String.valueOf(inv.B2B_Product__c));
            localSkusOrIds.remove(inv.B2B_Product__r.StockKeepingUnit);
        }
        for (Product2 p : [
                SELECT Id, StockKeepingUnit
                FROM Product2
                WHERE (StockKeepingUnit IN :localSkusOrIds OR Id IN :localSkusOrIds)
        ]) {
            SolarProductInventory pi = new SolarProductInventory();
            pi.currentWarehouseCode = currentWarehouse;
            pi.currentWarehouseInventory = 0;
            pi.otherWarehouseInventory = 0;
            pi.globalWarehouseInventory = 0;
            pi.productId = p.Id;
            productToInventoryMap.put(p.Id, pi);

//            productToInventoryMap.put(p.Id, new B2B_ProductInventory__c(B2B_InventoryAllocated__c = 0, B2B_InventoryOnHand__c = 0, B2B_InventoryOnOrder__c = 0));
            localSkusOrIds.remove(String.valueOf(p.Id));
            localSkusOrIds.remove(p.StockKeepingUnit);
        }
        for (String key : localSkusOrIds) {
            try {
                Id pId = (Id) key;
                if (!productToInventoryMap.containsKey(key)) {
                    SolarProductInventory pi = new SolarProductInventory();
                    pi.currentWarehouseCode = currentWarehouse;
                    pi.currentWarehouseInventory = 0;
                    pi.otherWarehouseInventory = 0;
                    pi.globalWarehouseInventory = 0;
                    pi.productId = pId;
                    productToInventoryMap.put(pId, pi);
                    //productToInventoryMap.put(pId, new B2B_ProductInventory__c(B2B_InventoryAllocated__c = 0, B2B_InventoryOnHand__c = 0, B2B_InventoryOnOrder__c = 0));
                }
            } catch (Exception e) {
                //do nothing.  An exception may occur due to the combination of SKUs and Ids.  Salesforce does not like when you use a sku as an ID.
                //Exceptions are expected and it is ok to ignore them here.
            }
        }
        return productToInventoryMap;
    }

