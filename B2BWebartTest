@IsTest
public with sharing class B2BWebCartHandlerTest {

    @IsTest
    static void testHandlerDirectCall() {

        // Create test user with correct profile
        Profile p = [SELECT Id FROM Profile 
                     WHERE Name = 'CloudCraze Customer Community Plus Login User' LIMIT 1];

        User u = new User(
            FirstName = 'Test',
            LastName = 'User',
            Email = 'handler@test.com',
            Username = 'handler' + DateTime.now().getTime() + '@test.com',
            Alias = 'huser',
            TimeZoneSidKey = 'Asia/Kolkata',
            LocaleSidKey = 'en_US',
            EmailEncodingKey = 'UTF-8',
            LanguageLocaleKey = 'en_US',
            ProfileId = p.Id
        );
        insert u;

        System.runAs(u) {

            // Set persona via session
            B2BUtil.updateSessionTrackerRealTime = false;
            B2BUtil.saveSessionInfoToPlatformSessionCache(
                null, true, 'DIST_AS_CUSTOMER', null, false, null, u.Id
            );

            List<WebCart> carts = new List<WebCart>{
                new WebCart(Name = 'Cart'),
                new WebCart(Name = null),
                new WebCart(Name = 'Random Name')
            };

            Test.startTest();
            B2BWebCartHandler.setCartNameFromPersona(carts);
            Test.stopTest();

            for(WebCart wc : carts){
                System.assertEquals('Cart DIST_AS_CUSTOMER', wc.Name);
            }
        }
    }

    @IsTest
    static void testHandlerInvalidPersona() {

        Profile p = [SELECT Id FROM Profile 
                     WHERE Name = 'CloudCraze Customer Community Plus Login User' LIMIT 1];

        User u = new User(
            FirstName = 'Test',
            LastName = 'User',
            Email = 'handler2@test.com',
            Username = 'handler2' + DateTime.now().getTime() + '@test.com',
            Alias = 'huser2',
            TimeZoneSidKey = 'Asia/Kolkata',
            LocaleSidKey = 'en_US',
            EmailEncodingKey = 'UTF-8',
            LanguageLocaleKey = 'en_US',
            ProfileId = p.Id
        );
        insert u;

        System.runAs(u) {

            B2BUtil.updateSessionTrackerRealTime = false;
            B2BUtil.saveSessionInfoToPlatformSessionCache(
                null, true, 'FOR_SELF', null, false, null, u.Id
            );

            List<WebCart> carts = new List<WebCart>{
                new WebCart(Name = 'Cart')
            };

            B2BWebCartHandler.setCartNameFromPersona(carts);

            System.assertEquals('Cart', carts[0].Name);
        }
    }
}