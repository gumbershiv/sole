import { LightningElement, api } from 'lwc';
import { PageLabelStoreMixin } from 'c/b2bPageLabelStoreMixin';
import {transformData} from './dataNormalizer';
import { genUtil, inventoryUtil } from 'c/b2bUtil';

export default class B2BProductInventory extends PageLabelStoreMixin (LightningElement) {

    constructor() {
        // Initializing the mixin with specific labels
        super('b2bProductInventory b2bBadges', true);
        console.log('supperr...', super.labels);
    }

    async connectedCallback() {
        if (!super.labels || genUtil.isProxyEmpty(super.labels)) {
            await super.connectedCallback();
        }
        console.log('suppr...', super.labels);
    }

    _inventory;
    _displayType;
    _normalizedData;

    @api
    set inventory(value) {
        this._inventory = value;
        console.log('[b2bProductInventory] inventory received from parent:', JSON.parse(JSON.stringify(value)));
        this.computeData();
    }

    get inventory() {
        return this._inventory;
    }

    @api
    set displayType(value) {
        this._displayType = value;
        this.computeData();
    }

    get displayType() {
        return this._displayType;
    }

    computeData() {
        this._normalizedData = transformData(
            this._inventory,
            this._displayType,
            inventoryUtil
        );
    }

    get showCurrentAvailability() {
        if (!this._normalizedData) {
            return false;
        }
        const status = this._normalizedData.currentWarehousestatus;
        return status !== 'Out of stock' && status !== 'Unavailable';
    }

    get showGlobalAvailability() {
        if (!this._normalizedData) {
            return false;
        }
        const status = this._normalizedData.globalWarehousestatus;
        return status !== 'Out of stock' && status !== 'Unavailable';
    }

    // For List view: show the small availability span when either current OR global status is In Stock or Limited stock
    get showListAvailability() {
        if (!this._normalizedData || !this._normalizedData.list) {
            return false;
        }
        // Use normalized flag computed in dataNormalizer.js for list view availability.
        return !!this._normalizedData.list.showAvailability;
    }

    get data() {
        return this._normalizedData;
    }

    // List view helpers: avoid complex expressions in template lwc:if attributes.
    get listShowLeadTime() {
        if (!this._normalizedData || !this._normalizedData.list) return false;
        return this._normalizedData.list.singleStatus === 'Out of stock' && !!this._normalizedData.list.leadTimeText;
    }

    get listShowInventory() {
        if (!this._normalizedData || !this._normalizedData.list) return false;
        const s = this._normalizedData.list.singleStatus;
        return (s === 'In Stock' || s === 'Limited stock') && !!this._normalizedData.list.showAvailability;
    }

    get listTooltipText() {
        if (!this._normalizedData || !this._normalizedData.list) return '';
        return this._normalizedData.list.tooltipText || '';
    }

    get tooltipContent() {
        if (!this._normalizedData) {
            return '';
        }

        const data = this._normalizedData;

        // Prefer list.tooltipText when available (normalized)
        if (data.list && data.list.tooltipText) {
            return data.list.tooltipText;
        }

        // Fallback to legacy behavior
        if (!data.showTooltip) {
            return '';
        }

        let content = `${data.inventoryAvailable.currentWarehouse} available in your current Warehouse. `;
        content += `${data.inventoryAvailable.otherWarehouse} available in alternate location. `;
        
        if (data.leadTime && data.leadTime.globalWarehouse) {
            content += `These will require up to ${data.leadTime.globalWarehouse}`;
        }

        return content;
    }
}

