/**
 * Display types
 */
const DISPLAY_TYPES = {
    LIST: 'list',
    PURCHASE: 'purchase',
    BASIC: 'basic'
};

/**
 * Normalize inventory data
 */
export function transformData(inventory, displayType = DISPLAY_TYPES.BASIC, inventoryUtil) {

    if (!inventory) {
        return createEmptyDisplayData();
    }

    const config = getDisplayConfig(displayType);
    const stock = extractInventory(inventory);
    const currentWarehouseLeadTime = extractLeadTime(inventory.currentWarehouseLeadTime);
    const globalWarehouseLeadTime = extractLeadTime(inventory.globalWarehouseLeadTime);
    const purchaseLimit = Number(inventory.purchaseLimit) || 0;
    const allowBackOrder = inventory.allowBackOrder !== undefined ? inventory.allowBackOrder : true;

    // Calculate statuses using utility functions
    const currentWarehousestatus = inventoryUtil.calculateStatus(
        inventory.currentWarehouseStatus,
        stock.current,
        purchaseLimit,
        allowBackOrder
    );
    
    const globalWarehousestatus = inventoryUtil.calculateStatus(
        inventory.otherWarehouseStatus,
        stock.global,
        purchaseLimit,
        allowBackOrder
    );

    // Determine basic display status (for basic display type only)
    const basicDisplayStatus = displayType === DISPLAY_TYPES.BASIC 
        ? inventoryUtil.determineBasicDisplayStatus(currentWarehousestatus, globalWarehousestatus)
        : null;

    // Compute list single status (priority rules)
    const singleStatus = (function() {
        if (currentWarehousestatus === 'In Stock' || globalWarehousestatus === 'In Stock') return 'In Stock';
        if (currentWarehousestatus === 'Limited stock' || globalWarehousestatus === 'Limited stock') return 'Limited stock';
        if (currentWarehousestatus === 'Out of stock' && globalWarehousestatus === 'Out of stock') return 'Out of stock';
        return 'Unavailable';
    })();

    // Suppression rules
    const suppressCurrentInventory = currentWarehousestatus === 'Out of stock' || currentWarehousestatus === 'Unavailable';
    const suppressGlobalInventory = globalWarehousestatus === 'Out of stock' || globalWarehousestatus === 'Unavailable';

    // For list view show the raw globalWarehouseInventory value (or 0 when suppressed)
    const summedGlobalAvailability = suppressGlobalInventory ? 0 : stock.global;

    // Tooltip rules: only for In Stock or Limited stock
    const tooltipText = (singleStatus === 'In Stock' || singleStatus === 'Limited stock')
        ? `${!suppressCurrentInventory ? `${stock.current} parts in your current warehouse. ` : ''}${!suppressGlobalInventory ? `${stock.global} parts available in alternate locations. ` : ''}These will require up to 14 days of additional processing time.`.trim()
        : '';

    // Lead time: show only when singleStatus is Out of stock
    const leadTimeText = singleStatus === 'Out of stock'
        ? (globalWarehousestatus === 'Out of stock' ? globalWarehouseLeadTime : currentWarehouseLeadTime)
        : null;

    // Flags for template (simple booleans)
    const showInventory = singleStatus === 'In Stock' || singleStatus === 'Limited stock';
    const showLeadTime = singleStatus === 'Out of stock' && !!leadTimeText;
    const showTooltip = !!tooltipText;

    // Build rows used by purchase view (preserve and adapt logic per latest spec)
    // Current row: expose inventoryCount and leadTime when applicable
    const currentRow = {
        statusLabel: currentWarehousestatus,
        availabilityText: suppressCurrentInventory ? null : stock.current,
        inventoryCount: suppressCurrentInventory ? 0 : stock.current,
        leadTimeText: currentWarehousestatus === 'Out of stock' ? currentWarehouseLeadTime : null,
        showIcon: currentWarehousestatus !== 'Unavailable',
        hideIcon: currentWarehousestatus === 'Unavailable',
        showAvailability: !suppressCurrentInventory
    };

    // Global/alternate row: use otherWarehouseInventory (stock.other). Hide the whole row when alternate status is Out of stock or Unavailable.
    const globalRow = {
        statusLabel: globalWarehousestatus,
        availabilityText: suppressGlobalInventory ? null : stock.other,
        inventoryCount: suppressGlobalInventory ? 0 : stock.other,
        leadTimeText: globalWarehousestatus === 'Out of stock' ? globalWarehouseLeadTime : null,
        // For in-stock/limited show a fixed processing message as before
        processingText: (globalWarehousestatus === 'In Stock' || globalWarehousestatus === 'Limited stock') ? 'Up to 14 days additional processing time required' : null,
        showIcon: globalWarehousestatus !== 'Unavailable',
        hideIcon: globalWarehousestatus === 'Unavailable',
        showAvailability: !suppressGlobalInventory
    };

    // Purchase row visibility logic (keep existing rules)
    let showPurchaseCurrent = true;
    let showPurchaseGlobal = true;

    if (globalWarehousestatus === 'Out of stock' && currentWarehousestatus === 'In Stock') {
        showPurchaseGlobal = false;
    }
    if (currentWarehousestatus === 'Unavailable' && globalWarehousestatus === 'Unavailable') {
        showPurchaseCurrent = true;
        showPurchaseGlobal = false;
    }
    if (currentWarehousestatus === 'Out of stock' && globalWarehousestatus === 'Out of stock') {
        showPurchaseGlobal = false;
        showPurchaseCurrent = true;
    }
    if (currentWarehousestatus === 'Limited stock' && globalWarehousestatus === 'Unavailable') {
        showPurchaseGlobal = false;
        showPurchaseCurrent = true;
    }
    if (currentWarehousestatus === 'Unavailable' && globalWarehousestatus === 'Limited stock') {
        showPurchaseCurrent = false;
        showPurchaseGlobal = true;
    }

    return {
        config,
        currentWarehousestatus,
        globalWarehousestatus,
        basicDisplayStatus,
        showTooltip,

        purchase: {
            showCurrent: showPurchaseCurrent,
            showGlobal: showPurchaseGlobal,
            // Expose counts for purchase view so template can show Current and alternate inventory
            currentRow: Object.assign({}, currentRow, {
                availabilityText: currentRow.availabilityText,
                inventoryCount: suppressCurrentInventory ? 0 : stock.current
            }),
            globalRow: Object.assign({}, globalRow, {
                availabilityText: globalRow.availabilityText,
                inventoryCount: suppressGlobalInventory ? 0 : stock.global
            })
        },

        list: {
            summedGlobalAvailability,
            singleStatus,
            tooltipText,
            leadTimeText,
            currentWarehouseCount: suppressCurrentInventory ? 0 : stock.current,
            globalWarehouseCount: suppressGlobalInventory ? 0 : stock.global,
            showAvailability: showInventory,
            showLeadTime,
            showInventory,
            showTooltip
        },

        inventoryAvailable: {
            currentWarehouse: stock.current,
            otherWarehouse: stock.other,
            global: stock.global
        },

        leadTime: {
            currentWarehouse: currentWarehouseLeadTime,
            globalWarehouse: globalWarehouseLeadTime
        },

        purchaseLimit,
        allowBackOrder,
        productId: inventory.productId || null,
        productSku: inventory.productSku || null,
        warehouse: {
            code: inventory.currentWarehouseCode || null
        },
        rawInventory: inventory
    };
}

/**
 * Display config
 */
function getDisplayConfig(displayType) {
    switch ((displayType || '').toLowerCase()) {

    case DISPLAY_TYPES.LIST:
        return { 
            isListView: true
        };

    case DISPLAY_TYPES.PURCHASE:
        return { 
            isPurchaseView: true
        };

    case DISPLAY_TYPES.BASIC:
    default:
        return { 
            isBasicView: true
        };
    }
}

/**
 * Inventory extraction
 */
function extractInventory(inventory) {

    const current = Number(inventory.currentWarehouseInventory) || 0;
    const other = Number(inventory.otherWarehouseInventory) || 0;
    const global = Number(inventory.globalWarehouseInventory) || 0;

    return {
        current,
        other,
        global
    };
}

/**
 * Lead time
 */
function extractLeadTime(leadTime) {

    if (leadTime === 'null' || leadTime === undefined || leadTime === null) {
        return null;
    }

    const days = Number(leadTime);

    if (isNaN(days)) {
        return null;
    }

    return `Lead time up to ${days} business day${days !== 1 ? 's' : ''}`;
}

/**
 * Empty fallback
 */
function createEmptyDisplayData() {
    return {
        config: { isBasicView: true },
        currentWarehousestatus: "In Stock",
        globalWarehousestatus: "In Stock",
        basicDisplayStatus: "In Stock",
        showTooltip: false,
        inventoryAvailable: {
            currentWarehouse: 0,
            otherWarehouse: 0,
            global: 0
        },
        leadTime: {
            currentWarehouse: null,
            globalWarehouse: null
        },
        purchaseLimit: 0,
        allowBackOrder: true,
        productId: null,
        productSku: null,
        warehouse: {
            code: null
        },
        rawInventory: null
    };
}

export { DISPLAY_TYPES };

