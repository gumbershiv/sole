const DISPLAY_TYPES = {
    LIST: 'list',
    PURCHASE: 'purchase',
    BASIC: 'basic'
};

const STATUS = {
    IN_STOCK: 'In Stock',
    LIMITED: 'Limited stock',
    OUT: 'Out of stock',
    UNAVAILABLE: 'Unavailable'
};

export function transformData(inventory, displayType = DISPLAY_TYPES.BASIC, inventoryUtil) {

    if (!inventory) {
        return createEmpty();
    }

    const config = getDisplayConfig(displayType);

    const stock = {
        current: Number(inventory.currentWarehouseInventory) || 0,
        alternate: Number(inventory.otherWarehouseInventory) || 0,
        global: Number(inventory.globalWarehouseInventory) || 0
    };

    const leadTime = {
        current: formatLead(inventory.currentWarehouseLeadTime),
        global: formatLead(inventory.globalWarehouseLeadTime)
    };

    const purchaseLimit = Number(inventory.purchaseLimit) || 0;
    const allowBackOrder = inventory.allowBackOrder ?? true;

    const statuses = {
        current: inventoryUtil.calculateStatus(
            inventory.currentWarehouseStatus,
            stock.current,
            purchaseLimit,
            allowBackOrder
        ),
        alternate: inventoryUtil.calculateStatus(
            inventory.otherWarehouseStatus,
            stock.alternate,
            purchaseLimit,
            allowBackOrder
        )
    };

    const singleStatus = resolveSingleStatus(statuses);

    return {
        config,
        statuses,

        list: buildList({
            stock,
            statuses,
            singleStatus,
            leadTime
        }),

        purchase: buildPurchase({
            stock,
            statuses,
            leadTime
        }),

        basicDisplayStatus:
            displayType === DISPLAY_TYPES.BASIC
                ? inventoryUtil.determineBasicDisplayStatus(
                      statuses.current,
                      statuses.alternate
                  )
                : null,

        inventoryAvailable: stock,
        leadTime,

        purchaseLimit,
        allowBackOrder,

        productId: inventory.productId || null,
        productSku: inventory.productSku || null,

        warehouse: {
            code: inventory.currentWarehouseCode || null
        },

        rawInventory: inventory
    };
}

/* ---------------- LIST ---------------- */

function buildList({ stock, statuses, singleStatus, leadTime }) {

    const showInventory = isAvailable(singleStatus);
    const showLeadTime = singleStatus === STATUS.OUT;

    return {
        singleStatus,
        globalAvailability: stock.global,

        tooltipText: showInventory
            ? buildTooltip(stock, statuses, leadTime)
            : '',

        leadTimeText: showLeadTime
            ? leadTime.global || leadTime.current
            : null,

        showInventory,
        showLeadTime,
        showTooltip: showInventory
    };
}

/* ---------------- PURCHASE ---------------- */

function buildPurchase({ stock, statuses, leadTime }) {

    const currentRow = buildRow({
        label: 'Current Warehouse',
        icon: 'utility:home',
        status: statuses.current,
        qty: stock.current,
        lead: leadTime.current
    });

    const alternateRow = buildRow({
        label: 'Alternate Warehouses',
        icon: 'utility:world',
        status: statuses.alternate,
        qty: stock.alternate,
        lead: leadTime.global
    });

    return {
        showCurrent:
            statuses.current !== STATUS.UNAVAILABLE ||
            statuses.alternate === STATUS.UNAVAILABLE,

        showAlternate:
            statuses.alternate !== STATUS.UNAVAILABLE &&
            !(statuses.alternate === STATUS.OUT &&
              statuses.current === STATUS.IN_STOCK),

        currentRow,
        alternateRow
    };
}

/* ---------------- ROW ---------------- */

function buildRow({ label, icon, status, qty, lead }) {

    const available = isAvailable(status);

    return {
        label,
        icon,
        statusLabel: status,

        availabilityText: available ? qty : null,
        inventoryCount: available ? qty : 0,

        leadTimeText: status === STATUS.OUT ? lead : null,

        processingText:
            available && icon === 'utility:world'
                ? 'Additional processing time may apply'
                : null,

        showAvailability: available,
        showIcon: status !== STATUS.UNAVAILABLE
    };
}

/* ---------------- HELPERS ---------------- */

function resolveSingleStatus({ current, alternate }) {

    if ([current, alternate].includes(STATUS.IN_STOCK)) {
        return STATUS.IN_STOCK;
    }

    if ([current, alternate].includes(STATUS.LIMITED)) {
        return STATUS.LIMITED;
    }

    if (current === STATUS.OUT && alternate === STATUS.OUT) {
        return STATUS.OUT;
    }

    return STATUS.UNAVAILABLE;
}

function isAvailable(status) {
    return status === STATUS.IN_STOCK || status === STATUS.LIMITED;
}

function buildTooltip(stock, statuses, leadTime) {

    let text = '';

    if (isAvailable(statuses.current)) {
        text += `${stock.current} in your warehouse. `;
    }

    if (isAvailable(statuses.alternate)) {
        text += `${stock.alternate} in alternate locations. `;
    }

    if (leadTime.global) {
        text += `May require ${leadTime.global}.`;
    }

    return text.trim();
}

function formatLead(val) {
    if (val == null || val === 'null') return null;
    const d = Number(val);
    if (isNaN(d)) return null;
    return `Lead time up to ${d} business day${d !== 1 ? 's' : ''}`;
}

function getDisplayConfig(type) {
    switch ((type || '').toLowerCase()) {
        case DISPLAY_TYPES.LIST:
            return { isListView: true };
        case DISPLAY_TYPES.PURCHASE:
            return { isPurchaseView: true };
        default:
            return { isBasicView: true };
    }
}

function createEmpty() {
    return {
        config: { isBasicView: true },
        statuses: { current: STATUS.IN_STOCK, alternate: STATUS.IN_STOCK },
        list: {
            singleStatus: STATUS.IN_STOCK,
            globalAvailability: 0,
            tooltipText: '',
            leadTimeText: null,
            showInventory: false,
            showLeadTime: false,
            showTooltip: false
        },
        purchase: {
            showCurrent: true,
            showAlternate: false,
            currentRow: {},
            alternateRow: {}
        },
        inventoryAvailable: { current: 0, alternate: 0, global: 0 },
        leadTime: { current: null, global: null }
    };
}

export { DISPLAY_TYPES };

import { LightningElement, api } from 'lwc';
import { PageLabelStoreMixin } from 'c/b2bPageLabelStoreMixin';
import { transformData } from './dataNormalizer';
import { genUtil, inventoryUtil } from 'c/b2bUtil';

export default class B2BProductInventory extends PageLabelStoreMixin(LightningElement) {

    _inventory;
    _displayType;

    _normalizedData = createSafeDefault();

    constructor() {
        super('b2bProductInventory b2bBadges', true);
    }

    async connectedCallback() {
        if (!super.labels || genUtil.isProxyEmpty(super.labels)) {
            await super.connectedCallback();
        }
    }

    @api
    set inventory(value) {
        this._inventory = value;
        this.compute();
    }

    @api
    set displayType(value) {
        this._displayType = value;
        this.compute();
    }

    compute() {
        this._normalizedData = transformData(
            this._inventory,
            this._displayType,
            inventoryUtil
        );
    }

    get data() {
        return this._normalizedData;
    }
}

/* prevent template crash */
function createSafeDefault() {
    return {
        config: {},
        list: {},
        purchase: {},
        statuses: {}
    };
}

<template>

    <!-- LIST -->
    <template lwc:if={data.config.isListView}>
        <div class="slds-grid">

            <c-b2b-badge status={data.list.singleStatus} labels={labels}></c-b2b-badge>

            <template lwc:if={data.list.showLeadTime}>
                <span>{data.list.leadTimeText}</span>
            </template>

            <template lwc:if={data.list.showInventory}>
                <span>{data.list.globalAvailability} {labels.Available}</span>
            </template>

            <template lwc:if={data.list.showTooltip}>
                <lightning-helptext content={data.list.tooltipText}></lightning-helptext>
            </template>

        </div>
    </template>

    <!-- BASIC -->
    <template lwc:elseif={data.config.isBasicView}>
        <div>
            ● {data.basicDisplayStatus}
        </div>
    </template>

    <!-- PURCHASE -->
    <template lwc:elseif={data.config.isPurchaseView}>

        <!-- CURRENT -->
        <template lwc:if={data.purchase.showCurrent}>
            <div>

                <template lwc:if={data.purchase.currentRow.showIcon}>
                    <lightning-icon icon-name={data.purchase.currentRow.icon}></lightning-icon>
                </template>

                <c-b2b-badge status={data.purchase.currentRow.statusLabel} labels={labels}></c-b2b-badge>

                <template lwc:if={data.purchase.currentRow.showAvailability}>
                    <span>{data.purchase.currentRow.availabilityText} {labels.Available}</span>
                </template>

                <template lwc:if={data.purchase.currentRow.leadTimeText}>
                    <span>{data.purchase.currentRow.leadTimeText}</span>
                </template>

            </div>
        </template>

        <!-- ALTERNATE -->
        <template lwc:if={data.purchase.showAlternate}>
            <div>

                <template lwc:if={data.purchase.alternateRow.showIcon}>
                    <lightning-icon icon-name={data.purchase.alternateRow.icon}></lightning-icon>
                </template>

                <c-b2b-badge status={data.purchase.alternateRow.statusLabel} labels={labels}></c-b2b-badge>

                <template lwc:if={data.purchase.alternateRow.showAvailability}>
                    <span>{data.purchase.alternateRow.availabilityText} {labels.Available}</span>
                </template>

                <template lwc:if={data.purchase.alternateRow.leadTimeText}>
                    <span>{data.purchase.alternateRow.leadTimeText}</span>
                </template>

                <template lwc:if={data.purchase.alternateRow.processingText}>
                    <span>{data.purchase.alternateRow.processingText}</span>
                </template>

            </div>
        </template>

    </template>

</template>
