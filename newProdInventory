<template>
    <!-- List Display Type: Show only current warehouse with tooltip -->
    <template lwc:if={data.config.isListView}>
        <div class="slds-grid slds-p-top_xx-small">
            <c-b2b-badge 
                status={data.list.singleStatus} 
                labels={labels}>
            </c-b2b-badge>&nbsp;&nbsp;

            <!-- Show lead time only for Out of stock -->
            <template lwc:if={data.list.showLeadTime}>
                <span class="data-label-text-small slds-p-top_x-small slds-p-bottom_x-small">
                    {data.list.leadTimeText}
                </span>&nbsp;
            </template>

            <!-- Show global inventory only for In Stock or Limited stock -->
            <template lwc:if={data.list.showInventory}>
                <span class="data-label-text-small slds-p-top_x-small slds-p-bottom_x-small">
                    {data.list.summedGlobalAvailability} {labels.Available}
                </span>&nbsp;&nbsp;
            </template>

            <!-- Tooltip: only for In Stock or Limited stock -->
            <template lwc:if={data.list.showTooltip}>
                <div class="slds-m-left_x-small">
                    <lightning-helptext 
                        content={data.list.tooltipText}
                        icon-name="utility:info"
                        alternative-text="Warehouse Information">
                    </lightning-helptext>
                </div>
            </template>
        </div>
    </template>

    <!-- Basic Display Type: Show status text with green dot -->
    <template lwc:elseif={data.config.isBasicView}>
        <div class="slds-grid slds-grid_vertical-align-center slds-p-top_xx-small">
            <span class="slds-text-color_success slds-m-right_xx-small" style="font-size: 1.2em;">●</span>
            <span class="data-label-text-small">{data.basicDisplayStatus}</span>
        </div>
    </template>

    <!-- Purchase Display Type: Show both current and global warehouse with normalized rules -->
    <template lwc:elseif={data.config.isPurchaseView}>
        <!-- Current warehouse row -->
        <template lwc:if={data.purchase.showCurrent}>
            <div class="slds-grid slds-p-top_xx-small"> 
                <template lwc:if={data.purchase.currentRow.showIcon}>
                    <lightning-icon
                        icon-name="utility:home"
                        alternative-text="Current warehouse"
                        size="small"
                        class="icon-left">
                    </lightning-icon>
                    <c-b2b-badge 
                        status={data.purchase.currentRow.statusLabel} 
                        labels={labels}>
                    </c-b2b-badge>&nbsp;&nbsp;
                </template>
                <template lwc:if={data.purchase.currentRow.hideIcon}>
                    <!-- no icon space -->
                    <span style="width:1.5rem;display:inline-block;"></span>&nbsp;&nbsp;
                </template>

                <template lwc:if={showCurrentAvailability}>
                    <span class="data-label-text-small slds-p-top_x-small slds-p-bottom_x-small">
                        {data.purchase.currentRow.availabilityText} {labels.Available}
                    </span>&nbsp;&nbsp;
                </template>

                <template lwc:if={data.purchase.currentRow.leadTimeText}>
                    <span class="data-label-text-small slds-p-top_x-small slds-p-bottom_x-small">
                        {data.purchase.currentRow.leadTimeText}
                    </span>&nbsp;
                </template>
            </div>
        </template>

        <!-- Global / alternate warehouses row -->
        <template lwc:if={data.purchase.showGlobal}>
            <div class="slds-grid slds-p-top_xx-small"> 
                <template lwc:if={data.purchase.globalRow.showIcon}>
                    <lightning-icon
                        icon-name="utility:world"
                        alternative-text="Global warehouse"
                        size="small"
                        class="icon-left">
                    </lightning-icon>
                    <c-b2b-badge 
                        status={data.purchase.globalRow.statusLabel} 
                        labels={labels}>
                    </c-b2b-badge>&nbsp;&nbsp;
                </template>
                <template lwc:if={data.purchase.globalRow.hideIcon}>
                    <span style="width:1.5rem;display:inline-block;"></span>&nbsp;&nbsp;
                </template>

                <template lwc:if={showGlobalAvailability}>
                    <span class="data-label-text-small slds-p-top_x-small slds-p-bottom_x-small">
                        {data.purchase.globalRow.availabilityText} {labels.Available}
                    </span>&nbsp;&nbsp;
                </template>

                <template lwc:if={data.purchase.globalRow.leadTimeText}>
                    <span class="data-label-text-small slds-p-top_x-small slds-p-bottom_x-small">
                        {data.purchase.globalRow.leadTimeText}
                    </span>&nbsp;
                </template>
            </div>
        </template>
    </template>
</template>
