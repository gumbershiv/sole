/**
 * Display types
 */
const DISPLAY_TYPES = {
    LIST: 'list',
    PURCHASE: 'purchase',
    BASIC: 'basic'
};

const STATUS = {
    IN_STOCK: 'In Stock',
    LIMITED: 'Limited stock',
    OUT: 'Out of stock',
    UNAVAILABLE: 'Unavailable'
};

export function transformData(
    inventory,
    displayType = DISPLAY_TYPES.BASIC,
    inventoryUtil
) {
    if (!inventory) {
        return createEmptyDisplayData();
    }

    const config = getDisplayConfig(displayType);
    const stock = extractInventory(inventory);

    const leadTimes = {
        current: extractLeadTime(inventory.currentWarehouseLeadTime),
        global: extractLeadTime(inventory.globalWarehouseLeadTime)
    };

    const purchaseLimit = Number(inventory.purchaseLimit) || 0;
    const allowBackOrder =
        inventory.allowBackOrder !== undefined
            ? inventory.allowBackOrder
            : true;

    // -----------------------------------
    // Statuses
    // -----------------------------------
    const statuses = {
        current: inventoryUtil.calculateStatus(
            inventory.currentWarehouseStatus,
            stock.current,
            purchaseLimit,
            allowBackOrder
        ),

        alternate: inventoryUtil.calculateStatus(
            inventory.otherWarehouseStatus,
            stock.alternate,
            purchaseLimit,
            allowBackOrder
        )
    };

    // -----------------------------------
    // Derived values
    // -----------------------------------
    const singleStatus = getSingleStatus(statuses);

    const listData = buildListData({
        stock,
        statuses,
        singleStatus,
        leadTimes
    });

    const purchaseData = buildPurchaseData({
        stock,
        statuses,
        leadTimes
    });

    const basicDisplayStatus =
        displayType === DISPLAY_TYPES.BASIC
            ? inventoryUtil.determineBasicDisplayStatus(
                  statuses.current,
                  statuses.alternate
              )
            : null;

    return {
        config,
        statuses,
        basicDisplayStatus,
        list: listData,
        purchase: purchaseData,

        inventoryAvailable: stock,
        leadTime: leadTimes,

        purchaseLimit,
        allowBackOrder,

        productId: inventory.productId || null,
        productSku: inventory.productSku || null,

        warehouse: {
            code: inventory.currentWarehouseCode || null
        },

        rawInventory: inventory
    };
}

/**
 * Build LIST view
 */
function buildListData({ stock, statuses, singleStatus, leadTimes }) {
    const showInventory = isAvailable(singleStatus);
    const showLeadTime = singleStatus === STATUS.OUT;

    const tooltipText = showInventory
        ? buildTooltip(stock, statuses, leadTimes)
        : '';

    return {
        singleStatus,
        globalAvailability: stock.global,
        tooltipText,
        leadTimeText: showLeadTime
            ? leadTimes.global || leadTimes.current
            : null,
        showInventory,
        showLeadTime,
        showTooltip: !!tooltipText
    };
}

/**
 * Build PURCHASE view
 */
function buildPurchaseData({ stock, statuses, leadTimes }) {
    const currentRow = buildWarehouseRow({
        label: 'Current Warehouse',
        icon: 'utility:home',
        status: statuses.current,
        inventory: stock.current,
        leadTime: leadTimes.current
    });

    const alternateRow = buildWarehouseRow({
        label: 'Alternate Warehouses',
        icon: 'utility:world',
        status: statuses.alternate,
        inventory: stock.alternate,
        leadTime: leadTimes.global
    });

    return {
        showCurrent:
            statuses.current !== STATUS.UNAVAILABLE ||
            statuses.alternate === STATUS.UNAVAILABLE,

        showAlternate:
            statuses.alternate !== STATUS.UNAVAILABLE &&
            !(statuses.alternate === STATUS.OUT &&
                statuses.current === STATUS.IN_STOCK),

        currentRow,
        alternateRow
    };
}

/**
 * Row builder
 */
function buildWarehouseRow({
    label,
    icon,
    status,
    inventory,
    leadTime
}) {
    const available = isAvailable(status);

    return {
        label,
        icon,
        statusLabel: status,
        inventoryCount: available ? inventory : 0,
        availabilityText: available ? inventory : null,
        leadTimeText: status === STATUS.OUT ? leadTime : null,
        processingText:
            available && icon === 'utility:world'
                ? 'Additional processing time may apply'
                : null,
        showAvailability: available,
        showIcon: status !== STATUS.UNAVAILABLE
    };
}

/**
 * Single badge status for list view
 */
function getSingleStatus(statuses) {
    const values = Object.values(statuses);

    if (values.includes(STATUS.IN_STOCK)) {
        return STATUS.IN_STOCK;
    }

    if (values.includes(STATUS.LIMITED)) {
        return STATUS.LIMITED;
    }

    if (values.every(status => status === STATUS.OUT)) {
        return STATUS.OUT;
    }

    return STATUS.UNAVAILABLE;
}

/**
 * Tooltip
 */
function buildTooltip(stock, statuses, leadTimes) {
    let message = '';

    if (isAvailable(statuses.current)) {
        message += `${stock.current} parts in your warehouse. `;
    }

    if (isAvailable(statuses.alternate)) {
        message += `${stock.alternate} parts in alternate locations. `;
    }

    if (leadTimes.global) {
        message += `May require ${leadTimes.global}.`;
    }

    return message.trim();
}

/**
 * Helpers
 */
function isAvailable(status) {
    return (
        status === STATUS.IN_STOCK ||
        status === STATUS.LIMITED
    );
}

function getDisplayConfig(displayType) {
    switch ((displayType || '').toLowerCase()) {
        case DISPLAY_TYPES.LIST:
            return { isListView: true };

        case DISPLAY_TYPES.PURCHASE:
            return { isPurchaseView: true };

        case DISPLAY_TYPES.BASIC:
        default:
            return { isBasicView: true };
    }
}

function extractInventory(inventory) {
    return {
        current: Number(inventory.currentWarehouseInventory) || 0,
        alternate: Number(inventory.otherWarehouseInventory) || 0,
        global: Number(inventory.globalWarehouseInventory) || 0
    };
}

function extractLeadTime(value) {
    if (
        value === null ||
        value === undefined ||
        value === 'null'
    ) {
        return null;
    }

    const days = Number(value);

    if (isNaN(days)) {
        return null;
    }

    return `Lead time up to ${days} business day${
        days !== 1 ? 's' : ''
    }`;
}

function createEmptyDisplayData() {
    return {
        config: { isBasicView: true },
        statuses: {
            current: STATUS.IN_STOCK,
            alternate: STATUS.IN_STOCK
        },
        basicDisplayStatus: STATUS.IN_STOCK,
        list: {},
        purchase: {},
        inventoryAvailable: {
            current: 0,
            alternate: 0,
            global: 0
        },
        leadTime: {
            current: null,
            global: null
        }
    };
}

export { DISPLAY_TYPES };



<template>

    <!-- LIST -->
    <template lwc:if={data.config.isListView}>
        <div class="slds-grid slds-p-top_xx-small">

            <c-b2b-badge
                status={data.list.singleStatus}
                labels={labels}>
            </c-b2b-badge>&nbsp;&nbsp;

            <template lwc:if={data.list.showLeadTime}>
                <span class="data-label-text-small">
                    {data.list.leadTimeText}
                </span>
            </template>

            <template lwc:if={data.list.showInventory}>
                <span class="data-label-text-small">
                    {data.list.globalAvailability}
                    {labels.Available}
                </span>
            </template>

            <template lwc:if={data.list.showTooltip}>
                <lightning-helptext
                    content={data.list.tooltipText}>
                </lightning-helptext>
            </template>
        </div>
    </template>

    <!-- BASIC -->
    <template lwc:elseif={data.config.isBasicView}>
        <div class="slds-grid slds-grid_vertical-align-center">
            <span class="slds-text-color_success">●</span>
            <span class="data-label-text-small">
                {data.basicDisplayStatus}
            </span>
        </div>
    </template>

    <!-- PURCHASE -->
    <template lwc:elseif={data.config.isPurchaseView}>

        <!-- Current -->
        <template lwc:if={data.purchase.showCurrent}>
            <div class="slds-grid slds-p-top_xx-small">

                <template lwc:if={data.purchase.currentRow.showIcon}>
                    <lightning-icon
                        icon-name={data.purchase.currentRow.icon}
                        size="small">
                    </lightning-icon>
                </template>

                <c-b2b-badge
                    status={data.purchase.currentRow.statusLabel}
                    labels={labels}>
                </c-b2b-badge>

                <template lwc:if={data.purchase.currentRow.showAvailability}>
                    <span class="data-label-text-small">
                        {data.purchase.currentRow.availabilityText}
                        {labels.Available}
                    </span>
                </template>

                <template lwc:if={data.purchase.currentRow.leadTimeText}>
                    <span class="data-label-text-small">
                        {data.purchase.currentRow.leadTimeText}
                    </span>
                </template>
            </div>
        </template>

        <!-- Alternate -->
        <template lwc:if={data.purchase.showAlternate}>
            <div class="slds-grid slds-p-top_xx-small">

                <template lwc:if={data.purchase.alternateRow.showIcon}>
                    <lightning-icon
                        icon-name={data.purchase.alternateRow.icon}
                        size="small">
                    </lightning-icon>
                </template>

                <c-b2b-badge
                    status={data.purchase.alternateRow.statusLabel}
                    labels={labels}>
                </c-b2b-badge>

                <template lwc:if={data.purchase.alternateRow.showAvailability}>
                    <span class="data-label-text-small">
                        {data.purchase.alternateRow.availabilityText}
                        {labels.Available}
                    </span>
                </template>

                <template lwc:if={data.purchase.alternateRow.leadTimeText}>
                    <span class="data-label-text-small">
                        {data.purchase.alternateRow.leadTimeText}
                    </span>
                </template>

                <template lwc:if={data.purchase.alternateRow.processingText}>
                    <span class="data-label-text-small">
                        {data.purchase.alternateRow.processingText}
                    </span>
                </template>
            </div>
        </template>

    </template>

</template>


import { LightningElement, api } from 'lwc';
import { PageLabelStoreMixin } from 'c/b2bPageLabelStoreMixin';
import { transformData } from './dataNormalizer';
import { genUtil, inventoryUtil } from 'c/b2bUtil';

export default class B2BProductInventory extends PageLabelStoreMixin(
    LightningElement
) {
    constructor() {
        super('b2bProductInventory b2bBadges', true);
    }

    async connectedCallback() {
        if (!super.labels || genUtil.isProxyEmpty(super.labels)) {
            await super.connectedCallback();
        }
    }

    _inventory;
    _displayType;
    _normalizedData;

    @api
    set inventory(value) {
        this._inventory = value;
        this.computeData();
    }

    @api
    set displayType(value) {
        this._displayType = value;
        this.computeData();
    }

    computeData() {
        this._normalizedData = transformData(
            this._inventory,
            this._displayType,
            inventoryUtil
        );
    }

    get data() {
        return this._normalizedData;
    }
}
