import { determineBasicDisplayStatus } from 'c/b2bUtil';

async validateCartItems(){
    const unavailableProducts = [];
    const replacedParts = [];
    const partsToAdd = [];

    if(this.cartItems.length > this.cart_ItemLimit){
        this.isLimitExcedeed = true;
        this.isLoading = false;
        return;
    } else {
        this.isLimitExcedeed = false;
    }

    this.cartItems.forEach((x) => {

        const inventory = x.inventory || {};

        // ✅ Purchase limit logic
        const purchaseLimit = inventory.allowBackOrder
            ? 99999
            : (inventory.globalWarehouseInventory || 0);

        x.purchaseLimit = purchaseLimit;

        // ✅ Use LABELS instead of hardcoded strings
        const getStatus = (qty) => {
            if (qty === 0) return super.labels.outOfStock;
            if (qty > 0 && qty <= 5) return super.labels.labelLimitedStock;
            if (qty > 5) return super.labels.inStock;
            return super.labels.itemUnavailableOrgCart; // fallback
        };

        const currentStatus = getStatus(inventory.currentWarehouseInventory);
        const otherStatus = getStatus(inventory.otherWarehouseInventory);

        const computedStatus = determineBasicDisplayStatus(currentStatus, otherStatus);

        const isOutOfStock = computedStatus === super.labels.outOfStock;
        const isInStock = computedStatus === super.labels.inStock;
        const isLimitedStock = computedStatus === super.labels.labelLimitedStock;
        const isUnavailable = computedStatus === super.labels.itemUnavailableOrgCart;

        // 🚨 Unavailable logic
        if (
            isUnavailable ||
            (
                (isOutOfStock || isInStock || isLimitedStock) &&
                (x.quantity > purchaseLimit || purchaseLimit === 0) &&
                (
                    x.finalPart === '' ||
                    x.finalPartId === '' ||
                    x.finalPartPurchaseLimit === 0 ||
                    (
                        x.finalPartId &&
                        x.finalPartPurchaseLimit &&
                        x.quantity > x.finalPartPurchaseLimit
                    )
                )
            )
        ){
            unavailableProducts.push({
                sku: x.sku,
                cartItemId : x.cartItemId
            });
        } else {

            if(x.quantity > purchaseLimit){
                if(x.finalPart && this.isValidSfId(x.finalPartId) && x.finalPartPurchaseLimit > 0){
                    replacedParts.push({
                        cartItemId: x.cartItemId,
                        item: x.sku,
                        itemId: x.productId,
                        replacedBy: x.finalPart,
                        replacedId: x.finalPartId
                    });
                } else {
                    unavailableProducts.push({
                        sku: x.sku,
                        cartItemId: x.cartItemId
                    });
                }
            }
        }
    });

    // 🔁 GROUPED VALIDATION
    const grouped = this.cartItems.reduce((duplicateProducts, item) => {
        if (!duplicateProducts[item.sku]) {
            duplicateProducts[item.sku] = {
                count : 0,
                quantity : 0,
                cartItemIds : [],
                purchaseLimit : item.purchaseLimit
            };
        }

        duplicateProducts[item.sku].count += 1;
        duplicateProducts[item.sku].quantity += item.quantity;
        duplicateProducts[item.sku].cartItemIds.push(item.cartItemId);

        return duplicateProducts;
    }, {});

    for (const [sku, {count, quantity, cartItemIds, purchaseLimit}] of Object.entries(grouped)) {
        if (count > 1 && quantity > purchaseLimit) {
            cartItemIds.forEach(id => {
                unavailableProducts.push({
                    sku: sku,
                    cartItemId : id
                });
            });
        }
    }

    // 🔁 Filter replaced parts
    if(replacedParts.length > 0){
        const filtered = replacedParts.filter(item =>
            !unavailableProducts.some(f => f.cartItemId === item.cartItemId)
        );
        replacedParts.length = 0;
        replacedParts.push(...filtered);
    }

    // 🚨 HANDLE UNAVAILABLE (unchanged)
    if(unavailableProducts.length > 0){
        const result = await validateAddToCart.open({
            size: 'small',
            content: unavailableProducts,
            cartValidation: true,
            headerTitle: super.labels.itemInsufficientOrgCart,
            unavailable: true,
            labelText: super.labels.stockAvailabilityNotice,
            buttonContinue: super.labels.continue,
            buttonCancel: super.labels.Cancel,
            bottomMessage: super.labels.cartUnavailableOrgModalMessage,
            replaced: false
        });

        if(result && result !== 'WOReplace'){
            if(replacedParts.length > 0){

                const response = await validateAddToCart.open({
                    size: 'small',
                    content: replacedParts,
                    headerTitle: super.labels.unavailableListItemsReplaceorgcart,
                    unavailable: false,
                    labelText: super.labels.replacementOfferedText,
                    buttonContinue: super.labels.continueReplacement,
                    buttonCancel: super.labels.continueWoReplacement,
                    columnTitle: super.labels.originalItemColumnTitle,
                    replaced: true
                });

                if(response && response !== 'WOReplace'){
                    partsToAdd.forEach(part => {
                        const source = replacedParts.find(src => src.itemId === part.productId);
                        if (source) {
                            part.productId = source.replacedId;
                        }
                    });

                    this.processesValidatedCartItems(unavailableProducts, replacedParts);

                } else if(response === 'WOReplace'){
                    replacedParts.forEach(part => {
                        unavailableProducts.push({
                            sku: part.item,
                            cartItemId: part.cartItemId
                        });
                    });

                    this.processesValidatedCartItems(unavailableProducts, null);
                } else {
                    this.isLoading = false;
                }

            } else {
                this.processesValidatedCartItems(unavailableProducts, null);
            }
        } else {
            this.fetchCartDetails(true);
        }

    } else {

        if(replacedParts.length > 0){

            const response = await validateAddToCart.open({
                size: 'small',
                content: replacedParts,
                headerTitle: super.labels.unavailableListItemsReplaceorgcart,
                unavailable: false,
                labelText: super.labels.replacementOfferedText,
                buttonContinue: super.labels.continueReplacement,
                buttonCancel: super.labels.continueWoReplacement,
                columnTitle: super.labels.originalItemColumnTitle,
                replaced: true
            });

            if(response && response !== 'WOReplace'){
                partsToAdd.forEach(part => {
                    const source = replacedParts.find(src => src.itemId === part.productId);
                    if (source) {
                        part.productId = source.replacedId;
                    }
                });

                this.processesValidatedCartItems(unavailableProducts, replacedParts);

            } else if(response === 'WOReplace'){
                replacedParts.forEach(part => {
                    unavailableProducts.push({
                        sku: part.item,
                        cartItemId: part.cartItemId
                    });
                });

                this.processesValidatedCartItems(unavailableProducts, null);
            } else {
                this.isLoading = false;
            }

        } else {
            this.triggerPriceCheck(true);
        }
    }
}