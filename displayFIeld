<template>
    <div class={computedHeaderClass}>

        <!-- Label -->
        <div class={computedLabelHeaderClass}>
            <span class={computedLabelClass}>
                {label}
            </span>
        </div>
        
        <!-- Value -->
        <div class={computedValueHeaderClass}>

            <template if:true={isCurrency}>
                <span class={computedValueClass}>
                    {currencyData.shortCurrSymbol}
                    <lightning-formatted-number 
                        value={numericValue}
                        minimum-fraction-digits="2"
                        maximum-fraction-digits="2">
                    </lightning-formatted-number>
                </span>

                <template if:true={longTermNeeded}>
                    <span class={computedValueClass}>
                        &nbsp;{currencyData.longCurrSymbol}
                    </span>
                </template>
            </template>

            <template if:false={isCurrency}>
                <lightning-formatted-text 
                    value={value}
                    class={computedValueClass}>
                </lightning-formatted-text>
            </template>

        </div>
    </div>
</template>

import { LightningElement, api } from 'lwc';
import { currencyUtil } from 'c/b2bUtil';

export default class B2bDisplayField extends LightningElement {

    // Public API
    @api label;
    @api value;
    @api classLabel;
    @api classValue;
    @api valueHeaderClass;
    @api labelHeaderClass;
    @api longTermNeeded = false;    
    @api classHeader; 
    @api currencyMap;
    @api currencyCode;

    // ---------- Computed Reactive Values ----------

    get isCurrency() {
        return !!this.currencyMap;
    }

    get currencyData() {
        return this.isCurrency
            ? currencyUtil.currencyData(this.currencyMap, this.currencyCode)
            : null;
    }

    get numericValue() {
        return Number(this.value || 0);
    }

    // ---------- Class Getters ----------

    get computedHeaderClass() {
        return this.classHeader || 
            'slds-grid slds-wrap slds-grid_align-spread slds-grid_vertical-align-end slds-p-vertical_xx-small slds-size_1-of-1';
    }

    get computedLabelClass() {
        return this.classLabel || 'data-label-text-medium';
    }

    get computedValueClass() {
        return this.classValue || 'solar-h6';
    }

    get computedValueHeaderClass() {
        return `slds-col slds-p-right--none ${
            this.valueHeaderClass || 'slds-text-align_left'
        }`;
    }

    get computedLabelHeaderClass() {
        return this.labelHeaderClass || 
            'slds-col slds-p-left--none slds-truncate';
    }
}