// =========================================================
// ✅ PURCHASE VIEW (CURRENT + ALTERNATE ONLY)
// =========================================================

// ---- STATUS (rename for clarity) ----
const alternateStatus = inventoryUtil.calculateStatus(
    inventory.otherWarehouseStatus,
    stock.other,
    purchaseLimit,
    allowBackOrder
);

// ---- SUPPRESSION ----
const suppressCurrent = currentStatus === STATUS.OUT || currentStatus === STATUS.UNAVAILABLE;
const suppressAlternate = alternateStatus === STATUS.OUT || alternateStatus === STATUS.UNAVAILABLE;

// ---- ROW BUILDER ----
const buildRow = (status, value, lead, suppress) => ({
    statusLabel: status,
    availabilityText: suppress ? null : value,
    leadTimeText: status === STATUS.OUT ? lead : null,
    showIcon: status !== STATUS.UNAVAILABLE,
    hideIcon: status === STATUS.UNAVAILABLE,
    showAvailability: !suppress
});

// ---- ROWS ----
const currentRow = buildRow(
    currentStatus,
    stock.current,
    currentLead,
    suppressCurrent
);

const alternateRow = {
    ...buildRow(
        alternateStatus,
        stock.other,
        globalLead, // still using same lead source if backend provides it
        suppressAlternate
    ),
    processingText: (alternateStatus === STATUS.IN || alternateStatus === STATUS.LIMITED)
        ? 'Up to 14 days additional processing time required'
        : null
};

// ---- VISIBILITY RULES ----
// Current → ALWAYS visible
const showCurrent = true;

// Alternate → ONLY if not unavailable
const showAlternate = alternateStatus !== STATUS.UNAVAILABLE;

// ---- FINAL OBJECT ----
const purchase = {
    showCurrent,
    showGlobal: showAlternate,   // keep name for HTML compatibility
    currentRow,
    globalRow: alternateRow     // reuse key to avoid HTML change
};
