const hasCurrent = stock.current > 0;
const hasAlternate = stock.other > 0;

let listTooltip = '';

if (hasCurrent && hasAlternate) {
    listTooltip = `${stock.current} parts in your current warehouse. ` +
                  `${stock.other} parts in your alternate warehouse. ` +
                  `These will take upto 14 days of additional processing time.`;
} 
else if (hasCurrent) {
    listTooltip = `${stock.current} parts in your current warehouse.`;
} 
else if (hasAlternate) {
    listTooltip = `${stock.other} parts in your alternate warehouse. ` +
                  `These will take upto 14 days of additional processing time.`;
}
