const STATUS = {
    IN: 'In Stock',
    LIMITED: 'Limited stock',
    OUT: 'Out of stock',
    UNAVAILABLE: 'Unavailable'
};

// ---- STATUS ----
const currentStatus = inventoryUtil.calculateStatus(
    inventory.currentWarehouseStatus,
    stock.current,
    purchaseLimit,
    allowBackOrder
);

const alternateStatus = inventoryUtil.calculateStatus(
    inventory.otherWarehouseStatus,
    stock.other,
    purchaseLimit,
    allowBackOrder
);

// ---- HELPERS ----
const isOut = s => s === STATUS.OUT;
const isUnavailable = s => s === STATUS.UNAVAILABLE;
const isInOrLimited = s => s === STATUS.IN || s === STATUS.LIMITED;

// ---- SUPPRESSION ----
const suppressCurrent = isOut(currentStatus) || isUnavailable(currentStatus);
const suppressAlternate = isOut(alternateStatus) || isUnavailable(alternateStatus);

// ---- ROW BUILDER ----
const buildRow = (status, value, lead, suppress, isAlternate = false) => ({
    statusLabel: status,
    availabilityText: suppress ? null : value,

    // ✅ Current → dynamic lead time
    // ❌ Alternate → no lead time
    leadTimeText: !isAlternate && isOut(status) ? lead : null,

    // ✅ Alternate → static processing text
    processingText: isAlternate && isInOrLimited(status)
        ? 'Up to 14 days additional processing time required'
        : null,

    showIcon: status !== STATUS.UNAVAILABLE,
    hideIcon: status === STATUS.UNAVAILABLE,
    showAvailability: !suppress
});

// ---- ROWS ----
const currentRow = buildRow(
    currentStatus,
    stock.current,
    currentLead,
    suppressCurrent,
    false
);

const alternateRow = buildRow(
    alternateStatus,
    stock.other,
    null, // no lead time
    suppressAlternate,
    true
);

// ---- VISIBILITY ----
const purchase = {
    showCurrent: true,
    showAlternate: alternateStatus !== STATUS.UNAVAILABLE,

    currentRow,
    alternateRow
};
