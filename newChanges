const STATUS = {
    IN: 'In Stock',
    LIMITED: 'Limited stock',
    OUT: 'Out of stock',
    UNAVAILABLE: 'Unavailable'
};

const isIn = s => s === STATUS.IN;
const isLimited = s => s === STATUS.LIMITED;
const isOut = s => s === STATUS.OUT;
const isUnavailable = s => s === STATUS.UNAVAILABLE;

// ---- STATUS ----
const currentStatus = inventoryUtil.calculateStatus(
    inventory.currentWarehouseStatus,
    stock.current,
    purchaseLimit,
    allowBackOrder
);

const alternateStatus = inventoryUtil.calculateStatus(
    inventory.otherWarehouseStatus,
    stock.other,
    purchaseLimit,
    allowBackOrder
);

// ---- FLAGS ----
const bothOut = isOut(currentStatus) && isOut(alternateStatus);
const bothUnavailable = isUnavailable(currentStatus) && isUnavailable(alternateStatus);

// ---- CURRENT ROW ----
const currentRow = {
    statusLabel: currentStatus,
    availabilityText: (!isOut(currentStatus) && !isUnavailable(currentStatus)) ? stock.current : null,

    // ✅ Lead time for IN + OUT
    leadTimeText: (isIn(currentStatus) || isOut(currentStatus)) ? currentLead : null,

    showIcon: !bothUnavailable,
    hideIcon: bothUnavailable,
    showAvailability: !isOut(currentStatus) && !isUnavailable(currentStatus)
};

// ---- ALTERNATE ROW ----
const alternateRow = {
    statusLabel: alternateStatus,
    availabilityText: (!isOut(alternateStatus) && !isUnavailable(alternateStatus)) ? stock.other : null,

    // ❌ NEVER show lead time
    leadTimeText: null,

    // ✅ Static message
    processingText: (isIn(alternateStatus) || isLimited(alternateStatus))
        ? 'Up to 14 days additional processing time required'
        : null,

    showIcon: !isUnavailable(alternateStatus) && !bothUnavailable,
    hideIcon: isUnavailable(alternateStatus) || bothUnavailable,
    showAvailability: !isOut(alternateStatus) && !isUnavailable(alternateStatus)
};

// ---- VISIBILITY ----
const purchase = {
    showCurrent: true,

    showAlternate:
        !bothOut &&
        !bothUnavailable &&
        !isUnavailable(alternateStatus),

    currentRow,
    alternateRow
};


<template>

    <!-- CURRENT -->
    <template lwc:if={data.purchase.showCurrent}>
        <div class="slds-grid slds-p-top_xx-small">

            <template lwc:if={data.purchase.currentRow.showIcon}>
                <lightning-icon icon-name="utility:home" size="small"></lightning-icon>
            </template>

            <c-b2b-badge 
                status={data.purchase.currentRow.statusLabel} 
                labels={labels}>
            </c-b2b-badge>

            <template lwc:if={data.purchase.currentRow.showAvailability}>
                <span class="data-label-text-small slds-p-left_small">
                    {data.purchase.currentRow.availabilityText} {labels.Available}
                </span>
            </template>

            <template lwc:if={data.purchase.currentRow.leadTimeText}>
                <span class="data-label-text-small slds-p-left_small">
                    {data.purchase.currentRow.leadTimeText}
                </span>
            </template>

        </div>
    </template>


    <!-- ALTERNATE -->
    <template lwc:if={data.purchase.showAlternate}>
        <div class="slds-grid slds-p-top_xx-small">

            <template lwc:if={data.purchase.alternateRow.showIcon}>
                <lightning-icon icon-name="utility:world" size="small"></lightning-icon>
            </template>

            <c-b2b-badge 
                status={data.purchase.alternateRow.statusLabel} 
                labels={labels}>
            </c-b2b-badge>

            <template lwc:if={data.purchase.alternateRow.showAvailability}>
                <span class="data-label-text-small slds-p-left_small">
                    {data.purchase.alternateRow.availabilityText} {labels.Available}
                </span>
            </template>

            <template lwc:if={data.purchase.alternateRow.processingText}>
                <span class="data-label-text-small slds-p-left_small">
                    ({data.purchase.alternateRow.processingText})
                </span>
            </template>

        </div>
    </template>

</template>
