/**
 * Display types
 */
const DISPLAY_TYPES = {
    LIST: 'list',
    PURCHASE: 'purchase',
    BASIC: 'basic'
};

/**
 * Normalize inventory data
 */
export function normalizeInventoryData(inventory, displayType = DISPLAY_TYPES.BASIC) {

    if (!inventory) {
        return createEmptyDisplayData();
    }

    const config = getDisplayConfig(displayType);
    const stock = extractInventory(inventory);
    const leadTime = extractLeadTime(inventory);

    return {
        // ✅ Pure pass-through (only trim for safety)
        status: inventory.status ? String(inventory.status).trim() : '',

        inventoryAvailable: stock.total,

        availability: {
            show: config.showAvailability && stock.total > 0,
            currentWarehouse: stock.current,
            otherWarehouse: stock.other,
            total: stock.total
        },

        leadTime: {
            show: config.showLeadTime && leadTime !== null,
            value: leadTime
        },

        purchaseLimit: Number(inventory.purchaseLimit) || null,

        sku: inventory.productSku || null,
        productId: inventory.productId || null,

        warehouse: {
            code: inventory.currentWarehouseCode || null
        },

        rawInventory: inventory
    };
}

/**
 * Display config
 */
function getDisplayConfig(displayType) {
    switch ((displayType || '').toLowerCase()) {

        case DISPLAY_TYPES.LIST:
            return { showAvailability: true, showLeadTime: false };

        case DISPLAY_TYPES.PURCHASE:
            return { showAvailability: true, showLeadTime: true };

        case DISPLAY_TYPES.BASIC:
        default:
            return { showAvailability: false, showLeadTime: false };
    }
}

/**
 * Inventory extraction
 */
function extractInventory(inventory) {

    const current = Number(inventory.currentWarehouseInventory) || 0;
    const other = Number(inventory.otherWarehouseInventory) || 0;
    const global = Number(inventory.globalWarehouseInventory) || 0;

    const total = global > 0 ? global : (current + other);

    return {
        current,
        other,
        total
    };
}

/**
 * Lead time
 */
function extractLeadTime(inventory) {

    let raw = inventory.currentWarehouseLeadTime;

    if (raw === 'null' || raw === undefined || raw === null) {
        return null;
    }

    const days = Number(raw);

    if (isNaN(days)) {
        return null;
    }

    if (days === 0) {
        return 'Available now';
    }

    return `Lead time up to ${days} business day${days !== 1 ? 's' : ''}`;
}

/**
 * Empty fallback
 */
function createEmptyDisplayData() {
    return {
        status: '',
        inventoryAvailable: 0,
        availability: {
            show: false,
            currentWarehouse: 0,
            otherWarehouse: 0,
            total: 0
        },
        leadTime: {
            show: false,
            value: null
        },
        purchaseLimit: null,
        sku: null,
        productId: null,
        warehouse: {
            code: null
        },
        rawInventory: null
    };
}

export { DISPLAY_TYPES };

import { LightningElement, api } from 'lwc';
import { normalizeInventoryData } from './dataNormalizer';

export default class B2BProductInventory extends LightningElement {

    _inventory;
    _displayType;
    _normalizedData;

    @api
    set inventory(value) {
        this._inventory = value;
        this.computeData();
    }

    get inventory() {
        return this._inventory;
    }

    @api
    set displayType(value) {
        this._displayType = value;
        this.computeData();
    }

    get displayType() {
        return this._displayType;
    }

    computeData() {
        this._normalizedData = normalizeInventoryData(
            this._inventory,
            this._displayType
        );
    }

    get data() {
        return this._normalizedData;
    }

    // Simple helpers for template
    get hasAvailability() {
        return this.data?.availability?.show;
    }

    get hasLeadTime() {
        return this.data?.leadTime?.show;
    }
}

<template>
    <template if:true={data}>

        <!-- STATUS BADGE -->
        <div class="slds-m-bottom_x-small">
            <span class="slds-badge">
                {data.status}
            </span>
        </div>

        <!-- AVAILABILITY -->
        <template if:true={hasAvailability}>
            <div class="slds-text-body_small slds-m-bottom_x-small">

                <div>
                    <strong>{data.availability.total}</strong> available
                </div>

                <template if:true={data.availability.currentWarehouse}>
                    <div>
                        {data.availability.currentWarehouse} in your warehouse
                    </div>
                </template>

                <template if:true={data.availability.otherWarehouse}>
                    <div>
                        {data.availability.otherWarehouse} in other warehouses
                    </div>
                </template>

            </div>
        </template>

        <!-- LEAD TIME -->
        <template if:true={hasLeadTime}>
            <div class="slds-text-color_weak slds-text-body_small">
                {data.leadTime.value}
            </div>
        </template>

    </template>
</template>

