@IsTest
public with sharing class B2BDistributorCartServiceTest {

    /* =====================================
       TEST SETUP
       ===================================== */
    @TestSetup
    static void setup() {

        Account acct = B2B_TestDataFactory.createAccount(false);
        acct.Name = 'Dist Test Account';
        insert acct;

        Contact c = B2B_TestDataFactory.createContact(acct);
        User u = B2B_TestDataFactory.createCommunityUser(c, 'dist.user@example.com');

        WebStore store = B2B_TestDataFactory.createWebStore();
        B2B_TestDataFactory.getNetwork();
        BuyerGroup bg = B2B_TestDataFactory.createBuyerGroup();
        B2B_TestDataFactory.createBuyerAccount(acct);
        B2B_TestDataFactory.createBuyerGroupMember(acct, bg);
        B2B_TestDataFactory.createWebStoreBuyerGroup(bg, store.Id);

        System.runAs(u) {
            B2BUtil.updateSessionTrackerRealTime = false;
            B2BUtil.saveSessionInfoToPlatformSessionCache(acct.Id, false);
        }
    }

    /* =====================================
       COMMON HELPERS
       ===================================== */

    private static TestData loadData() {
        TestData t = new TestData();
        t.acct = [SELECT Id FROM Account WHERE Name='Dist Test Account' LIMIT 1];
        t.user = [SELECT Id FROM User WHERE Username='dist.user@example.com' LIMIT 1];
        t.store = [SELECT Id FROM WebStore LIMIT 1];
        t.network = B2B_TestDataFactory.getNetwork();
        return t;
    }

    private static void setPersona(User u, Id acctId,
        B2BUtil.DistributorAction action,
        Boolean isDistributor) {

        System.runAs(u) {
            B2BUtil.updateSessionTrackerRealTime = false;
            B2BUtil.saveSessionInfoToPlatformSessionCache(
                (String)acctId,
                isDistributor,
                action == null ? null : action.toString(),
                null,
                false,
                null,
                u.Id
            );
        }
    }

    private static Id createCart(User u, Id storeId, Id acctId,
                                 String name, Boolean isSecondary) {

        Id cartId;
        System.runAs(u) {
            WebCart wc = new WebCart(
                Name = name,
                WebStoreId = storeId,
                AccountId = acctId,
                IsSecondary = isSecondary,
                Status = 'Active'
            );
            insert wc;
            cartId = wc.Id;
        }
        return cartId;
    }

    /* =====================================
       TEST CASES
       ===================================== */

    // 1️⃣ NOT IN SCOPE
    @IsTest
    static void test_NotInScope() {

        TestData t = loadData();
        setPersona(t.user, t.acct.Id, null, false);

        B2BActionResponse resp;

        Test.startTest();
        System.runAs(t.user) {
            resp = B2BDistributorCartService.handleDistributorCart(t.network.Id);
        }
        Test.stopTest();

        Assert.isFalse(resp.isSuccess);
        Assert.areEqual('Not in Scope', resp.message);
        Assert.isNull(resp.data);
    }


    // 2️⃣ Persona cart already PRIMARY
    @IsTest
    static void test_PersonaAlreadyPrimary() {

        TestData t = loadData();

        setPersona(t.user, t.acct.Id,
            B2BUtil.DistributorAction.AS_CUSTOMER, true);

        String personaName = 'Cart DIST_AS_CUSTOMER';

        createCart(t.user, t.store.Id, t.acct.Id, personaName, false);
        createCart(t.user, t.store.Id, t.acct.Id, 'Other', true);

        B2BActionResponse resp;

        Test.startTest();
        System.runAs(t.user) {
            resp = B2BDistributorCartService.handleDistributorCart(t.network.Id);
        }
        Test.stopTest();

        Assert.isFalse(resp.isSuccess);
        Assert.areEqual('Do Not Refresh Cart', resp.message);
    }


    // 3️⃣ Persona cart exists but SECONDARY (upgrade path)
    @IsTest
    static void test_PersonaSecondary_UpgradeToPrimary() {

        TestData t = loadData();

        setPersona(t.user, t.acct.Id,
            B2BUtil.DistributorAction.AS_CUSTOMER, true);

        Id primaryId =
            createCart(t.user, t.store.Id, t.acct.Id, 'PrimaryBefore', false);

        Id personaId =
            createCart(t.user, t.store.Id, t.acct.Id,
                'Cart DIST_AS_CUSTOMER', true);

        B2BActionResponse resp;

        Test.startTest();
        System.runAs(t.user) {
            resp = B2BDistributorCartService.handleDistributorCart(t.network.Id);
        }
        Test.stopTest();

        Assert.isTrue(resp.isSuccess);
        Assert.areEqual('Refresh Cart', resp.message);

        Map<Id, WebCart> carts = new Map<Id, WebCart>([
            SELECT Id, IsSecondary
            FROM WebCart
            WHERE Id IN :new List<Id>{primaryId, personaId}
        ]);

        Assert.isTrue(carts.get(primaryId).IsSecondary);
        Assert.isFalse(carts.get(personaId).IsSecondary);
    }


    // 4️⃣ Persona missing + existing primary (create new)
    @IsTest
    static void test_CreatePersona_DemoteExistingPrimary() {

        TestData t = loadData();

        setPersona(t.user, t.acct.Id,
            B2BUtil.DistributorAction.DOUBLE_DISCOUNT, true);

        Id oldPrimary =
            createCart(t.user, t.store.Id, t.acct.Id, 'OldPrimary', false);

        B2BActionResponse resp;

        Test.startTest();
        System.runAs(t.user) {
            resp = B2BDistributorCartService.handleDistributorCart(t.network.Id);
        }
        Test.stopTest();

        Assert.isTrue(resp.isSuccess);
        Assert.areEqual('Refresh Cart', resp.message);

        WebCart oldCart =
            [SELECT IsSecondary FROM WebCart WHERE Id=:oldPrimary];

        Assert.isTrue(oldCart.IsSecondary);
    }


    // 5️⃣ Persona missing + no existing primary
    @IsTest
    static void test_CreatePersona_NoExistingPrimary() {

        TestData t = loadData();

        setPersona(t.user, t.acct.Id,
            B2BUtil.DistributorAction.AS_CUSTOMER, true);

        System.runAs(t.user) {
            delete [
                SELECT Id FROM WebCart
                WHERE AccountId=:t.acct.Id
                AND WebStoreId=:t.store.Id
            ];
        }

        B2BActionResponse resp;

        Test.startTest();
        System.runAs(t.user) {
            resp = B2BDistributorCartService.handleDistributorCart(t.network.Id);
        }
        Test.stopTest();

        Assert.isTrue(resp.isSuccess);
        Assert.areEqual('Refresh Cart', resp.message);
        Assert.isNotNull(resp.data);
    }


    // 6️⃣ Catch block coverage
    @IsTest
    static void test_ExceptionPath() {

        TestData t = loadData();

        setPersona(t.user, null,
            B2BUtil.DistributorAction.AS_CUSTOMER, true);

        B2BActionResponse resp;

        Test.startTest();
        System.runAs(t.user) {
            resp = B2BDistributorCartService.handleDistributorCart(null);
        }
        Test.stopTest();

        Assert.isFalse(resp.isSuccess);
        Assert.isNotNull(resp.message);
    }


    /* ===================================== */
    private class TestData {
        Account acct;
        User user;
        WebStore store;
        Network network;
    }
}