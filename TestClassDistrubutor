    // Centralized data creation requested via @TestSetup
    @TestSetup
    static void testSetup() {
        // Account, Contact, User
        Account acct = B2B_TestDataFactory.createAccount(false);
        acct.Name = 'Dist Test Account';
        insert acct;
        
        Contact c = B2B_TestDataFactory.createContact(acct);
        User u = B2B_TestDataFactory.createCommunityUser(c, 'dist.user@example.com');
        
        // WebStore + Network and buyer access scaffolding (consistent with other tests)
        WebStore store = B2B_TestDataFactory.createWebStore();
        Network net = B2B_TestDataFactory.getNetwork();
        BuyerGroup buyerGroup = B2B_TestDataFactory.createBuyerGroup();
        BuyerAccount buyerAcct = B2B_TestDataFactory.createBuyerAccount(acct);
        BuyerGroupMember member = B2B_TestDataFactory.createBuyerGroupMember(acct, buyerGroup);
        WebStoreBuyerGroup wbg = B2B_TestDataFactory.createWebStoreBuyerGroup(buyerGroup, store.Id);
        
        // Seed session info so B2BUtil.getSessionInformation is established for this user
        System.runAs(u) {
            B2BUtil.updateSessionTrackerRealTime = false; // avoid upsert in setup noise
            B2BUtil.saveSessionInfoToPlatformSessionCache(acct.Id, false);
        }
    }
    
    private static TestData initialDataLoad() {
        TestData t = new TestData();
        t.acct = [SELECT Id FROM Account WHERE Name = 'Dist Test Account' LIMIT 1];
        t.user = [SELECT Id FROM User WHERE Username = 'dist.user@example.com' LIMIT 1];
        t.store = [SELECT Id FROM WebStore WHERE Name = 'Shop Solar' LIMIT 1];
        t.network = B2B_TestDataFactory.getNetwork();
        return t;
    }

    // Helper to configure persona in session
    private static void setPersonaSession(User u, Id effectiveAccountId, B2BUtil.DistributorAction action, Boolean isDistributor) {
        System.runAs(u) {
            B2BUtil.updateSessionTrackerRealTime = false;
            B2BUtil.saveSessionInfoToPlatformSessionCache(
                (String)effectiveAccountId,
                isDistributor,
                action == null ? null : action.toString(),
                null,
                false,
                null,
                u.Id
            );
        }
    }

    // Helper to insert a cart for a user/account/store
    private static Id makeCart(User u, WebStore store, Account acct, String name, Boolean isSecondary) {
        Id newCartId;
        System.runAs(u) {
            WebCart wc = new WebCart(
                Name = name,
                WebStoreId = store.Id,
                AccountId = acct.Id,
                IsSecondary = isSecondary,
                Status = 'Active'
            );
            insert wc;
            newCartId = wc.Id;
        }
        return newCartId;
    }

    @IsTest
    static void testPersonaNotInScope_returnsNotInScope() {
         TestData t = initialDataLoad();

        // Persona: ACTIVE_USER (non-distributor) - not in scope
        setPersonaSession(t.user, t.acct.Id, null, false);

        B2BActionResponse resp;
        Test.startTest();
        System.runAs(t.user) {
            resp = B2BDistributorCartService.handleDistributorCart(t.network.Id);
        }
        Test.stopTest();

        System.assertEquals(false, resp.isSuccess);
        System.assertEquals('Not in Scope', resp.message);
        System.assertEquals(null, resp.data);
    }
    
