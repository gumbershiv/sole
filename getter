    /**
    * @description B2B_SalesOfficeTaxAreaId__c for the current user's active cart
    * 
    * This method:
    * - Fetches cart using current user + accountId
    * - Updates B2B_SalesOfficeTaxAreaId__c with salesOfficeCode passed
    * - Stales out cart price check current
    * - Logs error and throws AuraHandledException for UI handling
    *
    * @param accountId Account Id of the current context
    * @param salesOfficeCode Selected Sales Office Code
    */
    @AuraEnabled
    public static void updateCartSalesOfficeTaxArea(Id accountId, String salesOfficeCode) {

        try {
            // Validate input
            if (accountId == null || String.isBlank(salesOfficeCode)) {
                throw new AuraHandledException('Invalid input parameters');
            }

            // querying the cart here to fetch only specific carts of the current user ( OwnerId = :UserInfo.getUserId())
            List<WebCart> carts = [
                SELECT Id, B2B_SalesOfficeTaxAreaId__c,B2B_PriceCheckCurrent__c
                FROM WebCart
                WHERE OwnerId = :UserInfo.getUserId()
                AND AccountId = :accountId
                AND (Status = 'Active' OR Status = 'Checkout')
            ];
            if(carts.isEmpty()){
                return;
            }
            WebCart cart = carts[0];
            // Update cart sales office tax area id
            cart.B2B_SalesOfficeTaxAreaId__c = 'D_' + salesOfficeCode;

            //stale out cart price check
            cart.B2B_PriceCheckCurrent__c = false;
            update cart;

        } catch (Exception ex) {

            B2BLoggingUtil.error(
                'CART_TAX_AREA_UPDATE_ERROR',
                'B2BCartWarehouseService',
                'updateCartSalesOfficeTaxArea',
                ex.getLineNumber(),
                'Error updating Sales Office Tax Area: ' + ex.getMessage(),
                'accountId=' + accountId + ', salesOffice=' + salesOfficeCode
            );

            B2BLoggingUtil.flush();

            throw new AuraHandledException('Failed to update cart tax area.');
        }
    }
}
