public with sharing class B2BWarehouseService {

    /**
     * =========================================================
     * 🔹 METHOD: getSalesOfficeWarehouse
     * =========================================================
     * Fetches warehouse and sales office data based on context.
     *
     * BEHAVIOR:
     * 1. If returnList = TRUE:
     *    - Fetches Account from session
     *    - Reads configured Sales Offices (semicolon separated)
     *    - Returns ALL matching warehouses from metadata
     *
     * 2. If returnList = FALSE:
     *    - First tries session (preferred)
     *    - Falls back to User → Contact
     *    - Returns only CURRENT selection
     *
     * RETURNS:
     * B2BActionResponse with:
     *   SUCCESS:
     *     - List mode:
     *         {
     *           warehouses: List<Map>,
     *           current: Map,
     *           hasMultiple: Boolean
     *         }
     *     - Single mode:
     *         {
     *           salesOfficeCode,
     *           warehouseCode,
     *           country
     *         }
     *
     *   FAILURE:
     *     - message + null data
     */
    public static B2BActionResponse getSalesOfficeWarehouse(Boolean returnList) {
        try {

            // Retrieve session info (may be null)
            B2BSessionInformation sessionInfo = B2BUtil.getSessionInformation();

            // Load all metadata once (avoids repeated queries)
            Map<String, B2B_SalesOfficeAddress__mdt> metaAll =
                B2B_SalesOfficeAddress__mdt.getAll();

            /**
             * Create index:
             * KEY   = SalesOfficeCode
             * VALUE = List of metadata records
             *
             * This enables O(1) lookup instead of scanning full metadata repeatedly
             */
            Map<String, List<B2B_SalesOfficeAddress__mdt>> metaBySO =
                new Map<String, List<B2B_SalesOfficeAddress__mdt>>();

            for (B2B_SalesOfficeAddress__mdt mdt : metaAll.values()) {
                if (String.isBlank(mdt.SalesOfficeCode__c)) continue;

                if (!metaBySO.containsKey(mdt.SalesOfficeCode__c)) {
                    metaBySO.put(mdt.SalesOfficeCode__c, new List<B2B_SalesOfficeAddress__mdt>());
                }
                metaBySO.get(mdt.SalesOfficeCode__c).add(mdt);
            }

            /* =====================================================
               ✅ CASE 1: RETURN LIST (ACCOUNT BASED)
            ===================================================== */
            if (returnList) {

                // Validate session + account
                if (sessionInfo == null || sessionInfo.effectiveAccountId == null) {
                    return new B2BActionResponse(false, 'No account in session', null);
                }

                // Fetch Account sales office configuration
                Account acc = [
                    SELECT cc_ST_Sales_Office__c
                    FROM Account
                    WHERE Id = :sessionInfo.effectiveAccountId
                    LIMIT 1
                ];

                if (String.isBlank(acc.cc_ST_Sales_Office__c)) {
                    return new B2BActionResponse(false, 'No sales offices configured', null);
                }

                // Convert semicolon string → Set for fast lookup
                Set<String> salesOffices =
                    new Set<String>(acc.cc_ST_Sales_Office__c.split(';'));

                List<Map<String, Object>> warehouses = new List<Map<String, Object>>();

                // Build warehouse list
                for (String so : salesOffices) {

                    if (!metaBySO.containsKey(so)) continue;

                    for (B2B_SalesOfficeAddress__mdt mdt : metaBySO.get(so)) {

                        warehouses.add(new Map<String, Object>{
                            'salesOfficeCode' => so,
                            'warehouseCode'   => mdt.WarehouseCode__c,
                            'country'         => getCountryName(mdt.WarehouseCountryCode__c),
                            'countryCode'     => mdt.WarehouseCountryCode__c,
                            'address'         => mdt.WarehouseAddress__c
                        });
                    }
                }

                // No metadata found
                if (warehouses.isEmpty()) {
                    return new B2BActionResponse(false, 'No warehouse metadata found', null);
                }

                // Return structured response
                return new B2BActionResponse(true, 'Success', new Map<String, Object>{
                    'warehouses'  => warehouses,
                    'current'     => warehouses[0], // default selection
                    'hasMultiple' => warehouses.size() > 1
                });
            }

            /* =====================================================
               ✅ CASE 2: SINGLE VALUE (SESSION → CONTACT)
            ===================================================== */

            String salesOfficeCode;
            String warehouseCode;

            // Prefer session values if present
            if (sessionInfo != null &&
                (!String.isBlank(sessionInfo.salesOfficeCode) ||
                 !String.isBlank(sessionInfo.warehouseCode))) {

                salesOfficeCode = sessionInfo.salesOfficeCode;
                warehouseCode   = sessionInfo.warehouseCode;

            } else {

                // Fallback to Contact values
                User u = [
                    SELECT Contact.B2B_SalesofficeSelected__c,
                           Contact.B2B_WarehouseCodeSelected__c
                    FROM User
                    WHERE Id = :UserInfo.getUserId()
                    LIMIT 1
                ];

                if (u.Contact == null) {
                    return new B2BActionResponse(false, 'No Contact associated', null);
                }

                salesOfficeCode = u.Contact.B2B_SalesofficeSelected__c;
                warehouseCode   = u.Contact.B2B_WarehouseCodeSelected__c;
            }

            // Validate result
            if (String.isBlank(salesOfficeCode) && String.isBlank(warehouseCode)) {
                return new B2BActionResponse(false, 'No sales office/warehouse found', null);
            }

            // Fetch country from metadata
            String country;
            if (!String.isBlank(salesOfficeCode) && metaBySO.containsKey(salesOfficeCode)) {
                B2B_SalesOfficeAddress__mdt mdt = metaBySO.get(salesOfficeCode)[0];
                country = getCountryName(mdt.WarehouseCountryCode__c);
            }

            return new B2BActionResponse(true, 'Success', new Map<String, Object>{
                'salesOfficeCode' => salesOfficeCode,
                'warehouseCode'   => warehouseCode,
                'country'         => country
            });

        } catch (Exception e) {
            return new B2BActionResponse(false, 'Error: ' + e.getMessage(), null);
        }
    }


    /**
     * =========================================================
     * 🔹 METHOD: updateContactAndSession
     * =========================================================
     * Updates:
     *   1. Platform session cache (always)
     *   2. User's Contact record (if available)
     *
     * FIELD HANDLING:
     * - Supports both standard and fallback field names
     * - Uses dynamic field detection for flexibility
     *
     * BEHAVIOR:
     * - Null/blank values are normalized
     * - Session updated even if Contact is not present
     * - Contact update is best-effort (non-blocking)
     */
    public static void updateContactAndSession(String warehouseCode, String salesOfficeCode) {

        // Normalize blank values
        if (String.isBlank(warehouseCode)) warehouseCode = null;
        if (String.isBlank(salesOfficeCode)) salesOfficeCode = null;

        // Fetch current user
        User u = [
            SELECT Id, ContactId, AccountId
            FROM User
            WHERE Id = :UserInfo.getUserId()
            LIMIT 1
        ];

        /* ================= SESSION UPDATE ================= */

        B2BSessionInformation current = B2BUtil.getSessionInformation();

        if (current == null) {
            // Create new session
            saveSessionInfoToPlatformSessionCache(
                u.AccountId,
                false,
                warehouseCode,
                salesOfficeCode
            );
        } else {
            // Update existing session
            saveSessionInfoToPlatformSessionCache(
                current.effectiveAccountId,
                current.isDistributor,
                current.distributorAction != null ? current.distributorAction.toString() : null,
                current.distributorParentAccount,
                current.isPunchout,
                current.punchoutConfigurationName,
                UserInfo.getUserId(),
                warehouseCode,
                salesOfficeCode
            );
        }

        /* ================= CONTACT UPDATE ================= */

        if (u.ContactId == null) return;

        Map<String, Schema.SObjectField> fields =
            Contact.SObjectType.getDescribe().fields.getMap();

        Contact c = new Contact(Id = u.ContactId);
        Boolean hasUpdate = false;

        // Sales Office field resolution
        if (fields.containsKey('Sales_Office_Code__c')) {
            c.put('Sales_Office_Code__c', salesOfficeCode);
            hasUpdate = true;
        } else if (fields.containsKey('B2B_SalesofficeSelected__c')) {
            c.put('B2B_SalesofficeSelected__c', salesOfficeCode);
            hasUpdate = true;
        }

        // Warehouse field resolution
        if (fields.containsKey('Warehouse_Code__c')) {
            c.put('Warehouse_Code__c', warehouseCode);
            hasUpdate = true;
        } else if (fields.containsKey('B2B_WarehouseCodeSelected__c')) {
            c.put('B2B_WarehouseCodeSelected__c', warehouseCode);
            hasUpdate = true;
        }

        if (!hasUpdate) return;

        try {
            update c;
        } catch (Exception e) {
            System.debug('Contact update failed: ' + e.getMessage());
        }
    }


    /**
     * =========================================================
     * 🔹 HELPER: getCountryName
     * =========================================================
     * Resolves country code → country name using metadata.
     *
     * OPTIMIZATION:
     * - Uses in-memory cache to avoid repeated loops
     */
    private static Map<String, String> countryCache = new Map<String, String>();

    private static String getCountryName(String code) {

        if (String.isBlank(code)) return code;

        if (countryCache.containsKey(code)) {
            return countryCache.get(code);
        }

        for (B2B_CountryAndStateList__mdt rec :
             B2B_CountryAndStateList__mdt.getAll().values()) {

            if (rec.B2B_Country_Code__c != null &&
                rec.B2B_Country_Code__c.equalsIgnoreCase(code)) {

                countryCache.put(code, rec.B2B_Country_Name__c);
                return rec.B2B_Country_Name__c;
            }
        }

        return code;
    }
}